---
interface Props {
  trialLinks?: { fanza?: string; dlsite?: string };
  location: string;
}
const { trialLinks, location } = Astro.props;
---

{(trialLinks?.fanza || trialLinks?.dlsite) && (
  <span class="hero-trial-group">
    <span class="hero-trial-label">無料体験版：</span>
    {trialLinks.fanza && (
      <a class="hero-trial-link" href={trialLinks.fanza} target="_blank" rel="noopener noreferrer"
         data-ga-event="trial_click" data-store="fanza" data-ga-location={location}>FANZA</a>
    )}
    {trialLinks.fanza && trialLinks.dlsite && <span class="hero-sub-sep">·</span>}
    {trialLinks.dlsite && (
      <a class="hero-trial-link" href={trialLinks.dlsite} target="_blank" rel="noopener noreferrer"
         data-ga-event="trial_click" data-store="dlsite" data-ga-location={location}>DLsite</a>
    )}
  </span>
)}
