<button class="back-to-top" id="back-to-top" aria-label="ページトップへ戻る">
  <svg
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <polyline points="18 15 12 9 6 15"></polyline>
  </svg>
</button>

<script>
  import { smoothScrollBehavior } from '../scripts/motion';

  let _bttCleanup: (() => void) | null = null;

  function init() {
    _bttCleanup?.();

    const btn = document.getElementById('back-to-top');
    if (!btn) return;

    const ac = new AbortController();
    const signal = ac.signal;

    window.addEventListener(
      'scroll',
      () => {
        btn.classList.toggle('is-visible', window.scrollY >= 300);
      },
      { passive: true, signal }
    );
    btn.addEventListener(
      'click',
      () => {
        window.scrollTo({ top: 0, behavior: smoothScrollBehavior() });
      },
      { signal }
    );

    _bttCleanup = () => {
      ac.abort();
      _bttCleanup = null;
    };
  }

  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-swap', () => _bttCleanup?.());
</script>
