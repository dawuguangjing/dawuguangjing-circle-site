---
import { withBase } from '../utils/withBase';
import TunaTank from './TunaTank.astro';

interface Props {
  slug: string;
  title: string;
  catch: string;
  cover: string;
  isR18: boolean;
  platformLinks: { fanza?: string; dlsite?: string };
  trialLinks?: { fanza?: string; dlsite?: string };
  sellingPoints?: string[];
}

const { slug, title, catch: catchPhrase, cover, isR18, platformLinks, trialLinks, sellingPoints } = Astro.props;
---

<section class="hero-banner">
  <!-- 背景: 魚 -->
  <TunaTank
    triggerSelector=".store-button, .hero-banner-detail-link"
    goldSpawnRate={0.5}
    fishes={[
      { dir: 'r', top: '15%', dur: '18s', delay: '0s',   size: 36 },
      { dir: 'l', top: '55%', dur: '24s', delay: '-7s',  size: 52 },
      { dir: 'r', top: '75%', dur: '14s', delay: '-4s',  size: 28 },
      { dir: 'l', top: '35%', dur: '30s', delay: '-12s', size: 60 },
      { dir: 'r', top: '88%', dur: '20s', delay: '-9s',  size: 44 },
      { dir: 'l', top: '62%', dur: '26s', delay: '-5s',  size: 54, gold: true },
    ]}
  />

  <div class="hero-banner-inner container">

    <!-- 左: テキスト -->
    <div class="hero-banner-text">
      <div class="hero-banner-eyebrow">
        <span class="hero-banner-tag">最新作</span>
        {isR18 && <span class="badge badge--r18">R18</span>}
      </div>
      <h2 class="hero-banner-title">{title}</h2>
      <p class="hero-banner-catch">{catchPhrase}</p>

      {sellingPoints && sellingPoints.length > 0 && (
        <ul class="selling-points">
          {sellingPoints.map((point) => <li>{point}</li>)}
        </ul>
      )}

      <div class="hero-banner-cta">
        {platformLinks.fanza && (
          <a class="store-button" href={platformLinks.fanza} target="_blank" rel="noopener noreferrer" data-store="fanza">
            <span>FANZA で購入</span><span class="arrow">→</span>
          </a>
        )}
        {platformLinks.dlsite && (
          <a class="store-button" href={platformLinks.dlsite} target="_blank" rel="noopener noreferrer" data-store="dlsite">
            <span>DLsite で購入</span><span class="arrow">→</span>
          </a>
        )}
      </div>

      <div class="hero-banner-sub">
        {(trialLinks?.fanza || trialLinks?.dlsite) && (
          <span class="hero-trial-group">
            <span class="hero-trial-label">無料体験版：</span>
            {trialLinks.fanza && (
              <a class="hero-trial-link" href={trialLinks.fanza} target="_blank" rel="noopener noreferrer">FANZA</a>
            )}
            {trialLinks.fanza && trialLinks.dlsite && <span class="hero-sub-sep">·</span>}
            {trialLinks.dlsite && (
              <a class="hero-trial-link" href={trialLinks.dlsite} target="_blank" rel="noopener noreferrer">DLsite</a>
            )}
          </span>
        )}
        <a class="hero-banner-detail-link" href={withBase(`works/${slug}/`)}>詳細を見る <span class="hero-detail-arrow">→</span></a>
      </div>
    </div>

    <!-- 右: カバー画像 -->
    <a class="hero-banner-cover" href={withBase(`works/${slug}/`)}>
      <img src={cover} alt={`${title} cover`} width="480" height="320" fetchpriority="high" loading="eager" />
    </a>

  </div>
</section>
