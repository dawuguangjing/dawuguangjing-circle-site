---
import { withBase } from '../utils/withBase';
import { IMAGE_DIMENSIONS } from '../utils/constants';
import { buildLinks, PURCHASE_LINK_ENTRIES } from '../utils/types';
import TunaTank from './TunaTank.astro';
import StoreButtonGroup from './StoreButtonGroup.astro';
import TrialLinks from './TrialLinks.astro';

interface Props {
  slug: string;
  title: string;
  catch: string;
  cover: string;
  isR18: boolean;
  platformLinks: { fanza?: string; dlsite?: string };
  trialLinks?: { fanza?: string; dlsite?: string };
  sellingPoints?: string[];
}

const {
  slug,
  title,
  catch: catchPhrase,
  cover,
  isR18,
  platformLinks,
  trialLinks,
  sellingPoints
} = Astro.props;
const purchaseLinks = buildLinks(platformLinks, PURCHASE_LINK_ENTRIES);
---

<section class="hero-banner">
  <!-- 背景: 魚 -->
  <TunaTank
    triggerSelector=".store-button, .hero-banner-detail-link"
    goldSpawnRate={0.5}
    fishes={[
      { dir: 'r', top: '15%', dur: '18s', delay: '0s', size: 36 },
      { dir: 'l', top: '55%', dur: '24s', delay: '-7s', size: 52 },
      { dir: 'r', top: '75%', dur: '14s', delay: '-4s', size: 28 },
      { dir: 'l', top: '35%', dur: '30s', delay: '-12s', size: 60 },
      { dir: 'r', top: '88%', dur: '20s', delay: '-9s', size: 44 },
      { dir: 'l', top: '62%', dur: '26s', delay: '-5s', size: 54, gold: true }
    ]}
  />

  <div class="hero-banner-inner container">
    <!-- 左: テキスト -->
    <div class="hero-banner-text">
      <div class="hero-banner-eyebrow">
        <span class="hero-banner-tag">最新作</span>
        {isR18 && <span class="badge badge--r18">R18</span>}
      </div>
      <h2 class="hero-banner-title">{title}</h2>
      <p class="hero-banner-catch">{catchPhrase}</p>

      {
        sellingPoints && sellingPoints.length > 0 && (
          <ul class="selling-points">
            {sellingPoints.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        )
      }

      <div class="hero-banner-cta">
        <StoreButtonGroup links={purchaseLinks} location="hero_banner" />
      </div>

      <div class="hero-banner-sub">
        <TrialLinks trialLinks={trialLinks} location="hero_banner" />
        <a class="hero-banner-detail-link" href={withBase(`works/${slug}/`)}
          >詳細を見る <span class="hero-detail-arrow">→</span></a
        >
      </div>
    </div>

    <!-- 右: カバー画像 -->
    <a class="hero-banner-cover" href={withBase(`works/${slug}/`)}>
      <img
        src={cover}
        alt=""
        width={IMAGE_DIMENSIONS.heroBanner.width}
        height={IMAGE_DIMENSIONS.heroBanner.height}
        fetchpriority="high"
        loading="eager"
      />
    </a>
  </div>
</section>
