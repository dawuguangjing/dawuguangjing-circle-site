---
interface Props {
  /**
   * ライトボックスで表示するメディアアイテムの CSS セレクター。
   * 各要素は data-lightbox-src / data-lightbox-type (image|video) / data-lightbox-alt 属性を持つこと。
   */
  itemSelector: string;
}

const { itemSelector } = Astro.props;
---

<dialog
  class="lightbox-overlay"
  id="lightbox"
  aria-label="ライトボックス"
  data-item-selector={itemSelector}
>
  <button class="lightbox-close" aria-label="閉じる">&times;</button>
  <button class="lightbox-prev" aria-label="前のメディア">
    <svg
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg
    >
  </button>
  <div class="lightbox-media">
    <img class="lightbox-img" src="" alt="" />
    <video class="lightbox-video" src="" controls playsinline></video>
  </div>
  <button class="lightbox-next" aria-label="次のメディア">
    <svg
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg
    >
  </button>
  <div class="lightbox-counter" aria-live="polite"></div>
  <div class="lightbox-hint" id="lightbox-hint" aria-hidden="true">
    <p class="lightbox-hint-desktop">
      ← → ナビゲーション &nbsp; ESC 閉じる &nbsp; F フルスクリーン
    </p>
    <p class="lightbox-hint-mobile">スワイプでナビゲーション &middot; ピンチでズーム</p>
  </div>
  <div class="lightbox-thumbs" role="list" aria-label="サムネイル一覧"></div>
</dialog>

<script>
  import '../scripts/lightbox';
</script>
