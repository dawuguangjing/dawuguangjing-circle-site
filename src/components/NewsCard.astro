---
import { withBase } from '../utils/withBase';
import { formatDate } from '../utils/format';
import { categoryLabels } from '../utils/labels';

interface Props {
  slug: string;
  title: string;
  date: Date;
  category: string;
  thumbnail?: string;
}

const { slug, title, date, category, thumbnail } = Astro.props;
---

<article class={`news-card${thumbnail ? ' has-thumb' : ''}`}>
  <span class="news-card-date">{formatDate(date)}</span>
  <div class="news-card-body">
    <h3><a class="news-card-link" href={withBase(`news/${slug}/`)}>{title}</a></h3>
    <p>
      <span class={`badge badge--${category}`}>{categoryLabels[category] ?? category}</span>
    </p>
  </div>
  {thumbnail && (
    <img class="news-card-thumb" src={thumbnail} alt="" loading="lazy" width="80" height="56" />
  )}
  <slot />
</article>
