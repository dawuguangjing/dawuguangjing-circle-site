---
import { withBase } from '../utils/withBase';
import { formatDate } from '../utils/format';
import { categoryLabels } from '../utils/labels';
import type { NewsCategory } from '../content/config';

interface Props {
  slug: string;
  title: string;
  date: Date;
  category: NewsCategory;
  thumbnail?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const { slug, title, date, category, thumbnail, loading = 'lazy', fetchpriority } = Astro.props;
const href = withBase(`news/${slug}/`);
---

<article class="news-card">
  <div class="news-card-cover">
    {thumbnail
      ? <img src={thumbnail} alt="" loading={loading} fetchpriority={fetchpriority} width="480" height="270" />
      : <div class="news-card-cover-empty"></div>
    }
  </div>
  <div class="news-card-body">
    <div class="news-card-meta">
      <span class={`badge badge--${category}`}>{categoryLabels[category] ?? category}</span>
      <time class="news-card-date" datetime={date.toISOString().slice(0, 10)}>{formatDate(date)}</time>
    </div>
    <h3 class="news-card-title">
      <a class="news-card-link" href={href}>{title}</a>
    </h3>
    <slot />
  </div>
</article>
