---
import TunaTank from './TunaTank.astro';

interface Props {
  ageKey: string;
  ageTtl: number;
}

const { ageKey, ageTtl } = Astro.props;
---

<div
  class="age-overlay"
  role="dialog"
  aria-modal="true"
  aria-labelledby="age-overlay-title"
  aria-describedby="age-overlay-desc"
  data-nosnippet
  data-age-key={ageKey}
  data-age-ttl={ageTtl}
>
  <TunaTank
    triggerSelector="#age-confirm-overlay"
    fishes={[
      { dir: 'r', top: '12%', dur: '14s', delay: '0s', size: 40 },
      { dir: 'l', top: '35%', dur: '20s', delay: '-6s', size: 56 },
      { dir: 'r', top: '60%', dur: '25s', delay: '-11s', size: 64 },
      { dir: 'l', top: '80%', dur: '11s', delay: '-3s', size: 30 },
      { dir: 'r', top: '48%', dur: '18s', delay: '-8s', size: 48 }
    ]}
  />
  <div class="age-gate-card">
    <h1 id="age-overlay-title">年齢確認</h1>
    <p id="age-overlay-desc">
      本サークルでは成人向け製品を取り扱っております。<br />
      あなたは18歳以上ですか？
    </p>
    <div class="age-gate-actions">
      <button class="button" id="age-confirm-overlay">はい（18歳以上）</button>
      <button class="button secondary" id="age-deny-overlay">いいえ</button>
    </div>
    <div class="age-gate-denied" id="age-denied-overlay" hidden>
      18歳未満の方はご利用いただけません。ブラウザを閉じてください。
    </div>
  </div>
</div>

<script>
  import { safeSet, safeRemove } from '../scripts/safe-storage';
  import { onTransitionEnd } from '../scripts/transition-end';
  import { trapFocus } from '../scripts/focus-trap';

  const overlay = document.querySelector<HTMLElement>('.age-overlay');
  if (overlay) {
    const ageKey = overlay.dataset.ageKey!;
    const ageTtl = Number(overlay.dataset.ageTtl);
    const btn = document.getElementById('age-confirm-overlay');
    const deny = document.getElementById('age-deny-overlay');
    const denied = document.getElementById('age-denied-overlay');

    btn?.addEventListener('click', () => {
      const expiry = String(Date.now() + ageTtl);
      safeSet(ageKey, expiry);
      safeSet(ageKey, expiry, 'session');
      const rm = matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (rm) {
        document.documentElement.classList.add('age-verified');
        return;
      }
      overlay.style.opacity = '0';
      onTransitionEnd(
        overlay,
        () => {
          document.documentElement.classList.add('age-verified');
        },
        400
      );
    });

    deny?.addEventListener('click', () => {
      safeRemove(ageKey);
      safeRemove(ageKey, 'session');
      if (denied) denied.removeAttribute('hidden');
      if (btn) {
        btn.setAttribute('disabled', '');
        btn.setAttribute('aria-disabled', 'true');
      }
      if (deny) {
        deny.setAttribute('disabled', '');
        deny.setAttribute('aria-disabled', 'true');
      }
    });

    const focusable = [btn, deny].filter((el): el is HTMLElement => !!el);
    overlay.addEventListener('keydown', (e) => trapFocus(e, focusable));
    btn?.focus();
  }
</script>
