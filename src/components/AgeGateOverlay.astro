---
import TunaTank from './TunaTank.astro';

interface Props {
  ageKey: string;
  ageTtl: number;
}

const { ageKey, ageTtl } = Astro.props;
---

<div class="age-overlay" role="dialog" aria-modal="true" aria-labelledby="age-overlay-title" aria-describedby="age-overlay-desc" data-nosnippet>
  <TunaTank
    triggerSelector="#age-confirm-overlay"
    fishes={[
      { dir: 'r', top: '12%', dur: '14s', delay: '0s',   size: 40 },
      { dir: 'l', top: '35%', dur: '20s', delay: '-6s',  size: 56 },
      { dir: 'r', top: '60%', dur: '25s', delay: '-11s', size: 64 },
      { dir: 'l', top: '80%', dur: '11s', delay: '-3s',  size: 30 },
      { dir: 'r', top: '48%', dur: '18s', delay: '-8s',  size: 48 },
    ]}
  />
  <div class="age-gate-card">
    <h1 id="age-overlay-title">年齢確認</h1>
    <p id="age-overlay-desc">
      本サークルでは成人向け製品を取り扱っております。<br />
      あなたは18歳以上ですか？
    </p>
    <div class="age-gate-actions">
      <button class="button" id="age-confirm-overlay">はい（18歳以上）</button>
      <button class="button secondary" id="age-deny-overlay">いいえ</button>
    </div>
    <div class="age-gate-denied" id="age-denied-overlay" hidden>
      18歳未満の方はご利用いただけません。ブラウザを閉じてください。
    </div>
  </div>
</div>

<script is:inline define:vars={{ ageKey, ageTtl }}>
  (function() {
    var btn    = document.getElementById('age-confirm-overlay');
    var deny   = document.getElementById('age-deny-overlay');
    var denied = document.getElementById('age-denied-overlay');

    if (btn) {
      btn.addEventListener('click', function() {
        try {
          localStorage.setItem(ageKey, String(Date.now() + ageTtl));
        } catch(e) {
          try { sessionStorage.setItem(ageKey, String(Date.now() + ageTtl)); } catch(e2) {}
        }
        var overlay = document.querySelector('.age-overlay');
        var rm = matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (!overlay || rm) {
          document.documentElement.classList.add('age-verified');
          return;
        }
        overlay.style.opacity = '0';
        var done = false;
        function finish() {
          if (done) return;
          done = true;
          document.documentElement.classList.add('age-verified');
        }
        overlay.addEventListener('transitionend', finish, { once: true });
        setTimeout(finish, 400);
      });
    }
    if (deny) {
      deny.addEventListener('click', function() {
        try { localStorage.removeItem(ageKey); } catch(e) {}
        try { sessionStorage.removeItem(ageKey); } catch(e) {}
        if (denied) denied.removeAttribute('hidden');
        if (btn) { btn.setAttribute('disabled', ''); btn.setAttribute('aria-disabled', 'true'); }
        deny.setAttribute('disabled', '');
      });
    }
    if (btn) btn.focus();
  })();
</script>
