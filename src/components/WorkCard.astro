---
import { withBase } from '../utils/withBase';
import { formatDate } from '../utils/format';

interface Props {
  slug: string;
  title: string;
  cover: string;
  description: string;
  releaseDate: Date;
  isR18: boolean;
  hasTrial?: boolean;
  showEnvironments?: boolean;
  environments?: { windows?: boolean; mac?: boolean; browserPc?: boolean; ios?: boolean; android?: boolean };
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const {
  slug,
  title,
  cover,
  description,
  releaseDate,
  isR18,
  hasTrial = false,
  showEnvironments = false,
  environments,
  loading = 'lazy',
  fetchpriority,
} = Astro.props;

const MS_30_DAYS = 30 * 24 * 60 * 60 * 1000;
const isNew = Date.now() - releaseDate.getTime() < MS_30_DAYS;
---

<a class="work-row" href={withBase(`works/${slug}/`)} data-astro-prefetch>
  <div class="work-row-cover img-skeleton">
    <img
      src={withBase(cover)}
      alt={`${title} cover`}
      loading={loading}
      fetchpriority={fetchpriority}
      sizes="(max-width: 640px) 96px, 160px"
      width="160"
      height="160"
    />
    <div class="work-row-overlay" aria-hidden="true">
      <span class="card-view-label">詳細を見る</span>
    </div>
  </div>
  <div class="work-row-body">
    <h3>{title}</h3>
    <p class="work-row-desc">{description}</p>
    <div class="work-row-meta">
      <span class="work-row-date">{formatDate(releaseDate)}</span>
      <div class="work-row-tags">
        {isNew && <span class="badge badge--new">NEW</span>}
        {hasTrial && <span class="badge badge--trial">体験版あり</span>}
        {isR18 && <span class="badge badge--r18">R18</span>}
        {showEnvironments && environments?.windows && <span class="badge">Win</span>}
        {showEnvironments && environments?.mac && <span class="badge">Mac</span>}
        {showEnvironments && environments?.browserPc && <span class="badge">Browser</span>}
        {showEnvironments && environments?.ios && <span class="badge">iOS</span>}
        {showEnvironments && environments?.android && <span class="badge">Android</span>}
      </div>
    </div>
  </div>
</a>
