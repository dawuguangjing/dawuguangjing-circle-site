---
import { withBase } from '../utils/withBase';

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;

const allCrumbs = [{ label: 'ホーム', href: withBase('') }, ...crumbs];
const origin = Astro.url.origin;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: allCrumbs.map((crumb, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: crumb.label,
    ...(crumb.href ? { item: origin + crumb.href } : {}),
  })),
};
---

<nav class="breadcrumb" aria-label="パンくずリスト">
  <ol class="breadcrumb-list">
    <li class="breadcrumb-item">
      <a href={withBase('')}>ホーム</a>
    </li>
    {crumbs.map((crumb, i) => (
      <li class="breadcrumb-item" aria-current={i === crumbs.length - 1 ? 'page' : undefined}>
        {crumb.href
          ? <a href={crumb.href}>{crumb.label}</a>
          : <span>{crumb.label}</span>
        }
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
