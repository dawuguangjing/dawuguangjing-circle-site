---
import { withBase } from '../utils/withBase';
import { formatDate } from '../utils/format';

interface Props {
  slug: string;
  title: string;
  cover: string;
  isR18: boolean;
  releaseDate: Date;
  imageCount?: number;
  previewImage?: string;
  /** 先頭カード（LCP候補）は 'eager' + 'high' を渡す */
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const { slug, title, cover, isR18, releaseDate, imageCount, previewImage, loading = 'lazy', fetchpriority } = Astro.props;
---

<a class="gallery-card" href={withBase(`gallery/${slug}/`)}>
  <div class={`gallery-card-img-wrap img-skeleton${previewImage ? ' gallery-card-img-wrap--has-preview' : ''}`}>
    <img
      class="gallery-card-img"
      src={cover}
      alt={`${title} cover`}
      loading={loading}
      fetchpriority={fetchpriority}
      width="400"
      height="300"
    />
    {previewImage && (
      <img
        class="gallery-card-img gallery-card-img--preview"
        src={previewImage}
        alt=""
        loading="lazy"
        width="400"
        height="300"
        aria-hidden="true"
      />
    )}
    <div class="gallery-card-overlay" aria-hidden="true">
      <span class="card-view-label">詳細を見る</span>
    </div>
  </div>
  <div class="gallery-card-footer">
    <h3 class="gallery-card-title">{title}</h3>
    <div class="gallery-card-meta">
      <span class="gallery-card-date">{formatDate(releaseDate)}</span>
      <div class="gallery-card-badges">
        {isR18 && <span class="badge badge--r18">R18</span>}
        {imageCount != null && <span class="gallery-card-count">{imageCount}枚</span>}
      </div>
    </div>
  </div>
</a>
