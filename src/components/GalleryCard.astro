---
import { withBase } from '../utils/withBase';
import { IMAGE_DIMENSIONS, IMAGE_SIZES } from '../utils/constants';
import type { ImageLoadProps } from '../utils/types';

interface Props extends ImageLoadProps {
  slug: string;
  title: string;
  cover: string;
  isR18: boolean;
  imageCount?: number;
  previewImage?: string;
  previewImages?: string[];
}

const { slug, title, cover, isR18, imageCount, previewImage, previewImages, loading = 'lazy', fetchpriority } = Astro.props;
const thumbs = previewImages?.slice(0, 3) ?? [];
const { width: gw, height: gh } = IMAGE_DIMENSIONS.galleryCard;
const gSizes = IMAGE_SIZES.galleryCard;
---

<a class="card-interactive gallery-card" href={withBase(`gallery/${slug}/`)} data-astro-prefetch>
  <div class={`gallery-card-media img-skeleton${thumbs.length > 0 ? ' gallery-card-media--split' : ''}${previewImage ? ' gallery-card-media--has-preview' : ''}`}>
    <div class="gallery-card-media-cover">
      <img
        class="gallery-card-img"
        src={cover}
        alt={`${title} cover`}
        loading={loading}
        fetchpriority={fetchpriority}
        sizes={gSizes}
        width={gw}
        height={gh}
      />
      {previewImage && (
        <img
          class="gallery-card-img gallery-card-img--preview"
          src={previewImage}
          alt=""
          loading="lazy"
          sizes={gSizes}
          width={gw}
          height={gh}
          aria-hidden="true"
        />
      )}
      <div class="gallery-card-overlay" aria-hidden="true">
        <span class="card-view-label">詳細を見る</span>
      </div>
    </div>
    {thumbs.length > 0 && (
      <div class="gallery-card-media-thumbs">
        {thumbs.map((img) => (
          <div class="gallery-card-media-thumb">
            <img src={img} alt="" loading="lazy" width={gw} height={gh} aria-hidden="true" />
          </div>
        ))}
      </div>
    )}
  </div>
  <div class="gallery-card-footer">
    <h3 class="gallery-card-title">{title}</h3>
    <div class="gallery-card-meta">
      <div class="gallery-card-badges">
        {isR18 && <span class="badge badge--r18">R18</span>}
        {imageCount != null && <span class="gallery-card-count">{imageCount}枚</span>}
      </div>
    </div>
  </div>
</a>
