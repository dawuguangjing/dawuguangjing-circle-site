---
import { withBase } from '../utils/withBase';
import { mainNav } from '../utils/navigation';
import DarkModeToggle from './DarkModeToggle.astro';

const currentPath = Astro.url.pathname;
const basePath = import.meta.env.BASE_URL;
const isTop = currentPath === basePath || currentPath + '/' === basePath;
---

<header class="site-header">
  <div class="container site-header-inner">
    <a
      class:list={['logo', { 'logo--is-top': isTop }]}
      href={withBase('')}
      aria-label="ダウグアングジング公式 トップページへ"
    >
      <span class="logo-char" style="--i:0">ダ</span><span
        class="logo-char logo-accent"
        style="--i:1">ウ</span
      ><span class="logo-char logo-pink" style="--i:2">グ</span><span
        class="logo-char logo-pink"
        style="--i:3">ア</span
      ><span class="logo-char logo-pink" style="--i:4">ン</span><span
        class="logo-char logo-pink"
        style="--i:5">グ</span
      ><span class="logo-char" style="--i:6">ジ</span><span class="logo-char" style="--i:7">ン</span
      ><span class="logo-char" style="--i:8">グ</span><span class="logo-char" style="--i:9">公</span
      ><span class="logo-char" style="--i:10">式</span>
    </a>
    <nav class="nav-links" id="main-nav" aria-label="メインナビゲーション">
      {
        mainNav.map((item) => (
          <a
            href={item.href}
            {...(currentPath.startsWith(item.href)
              ? { 'aria-current': 'page', class: 'is-active' }
              : {})}
          >
            {item.label.split('').map((char, i) => (
              <span class="nav-char" style={`--i:${i}`}>
                {char}
              </span>
            ))}
          </a>
        ))
      }
    </nav>
    <div class="header-right">
      <DarkModeToggle />
      <button class="mobile-menu-toggle" aria-label="メニューを開く" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>
</header>

<script>
  import { lockScroll, unlockScroll } from '../scripts/scroll-lock';
  import { trapFocus } from '../scripts/focus-trap';
  import {
    HEADER_MENU_CLOSE_MS,
    HEADER_HIDE_THRESHOLD_PX,
    HEADER_SCROLL_DELTA_PX
  } from '../utils/constants';

  function getMenuElements() {
    return {
      header: document.querySelector<HTMLElement>('.site-header'),
      toggle: document.querySelector('.mobile-menu-toggle') as HTMLButtonElement | null,
      nav: document.getElementById('main-nav')
    };
  }

  function closeMenu() {
    const { header, toggle, nav } = getMenuElements();
    if (!toggle || !nav || !nav.classList.contains('is-open')) return;
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'メニューを開く');
    nav.classList.add('is-closing');
    let finalized = false;
    const finalizeClose = () => {
      if (finalized) return;
      finalized = true;
      nav.classList.remove('is-open', 'is-closing');
      header?.classList.remove('is-menu-open');
      unlockScroll('mobile-menu');
    };
    nav.addEventListener('animationend', finalizeClose, { once: true });
    // フォールバック
    setTimeout(finalizeClose, HEADER_MENU_CLOSE_MS);
  }

  function openMenu() {
    const { header, toggle, nav } = getMenuElements();
    if (!toggle || !nav) return;
    // メニューを開く際はヘッダーを強制表示（hide-on-scroll で隠れている場合）
    header?.classList.remove('is-hidden');
    header?.classList.add('is-menu-open');
    toggle.setAttribute('aria-expanded', 'true');
    toggle.setAttribute('aria-label', 'メニューを閉じる');
    nav.classList.add('is-open');
    lockScroll('mobile-menu');
  }

  // モバイルメニューのイベントは page-load ごとに再初期化（VTでDOMが差し替わるため）
  // AbortController の signal オプションに依存せず、常に明示的にクリーンアップする。
  let _cleanupMenuListeners: (() => void) | null = null;
  function initMobileMenu() {
    _cleanupMenuListeners?.();
    const { toggle, nav } = getMenuElements();
    if (!toggle || !nav) return;

    const onToggleClick = (e: MouseEvent) => {
      // 同一タップ中に document 側 click で即時 close されるのを防ぐ
      e.stopPropagation();
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      expanded ? closeMenu() : openMenu();
    };
    toggle.addEventListener('click', onToggleClick);

    const linkCleanupFns: Array<() => void> = [];
    nav.querySelectorAll<HTMLAnchorElement>('a[href]').forEach((link) => {
      const onLinkClick = () => {
        closeMenu();
        requestAnimationFrame(() => toggle.focus());
      };
      link.addEventListener('click', onLinkClick);
      linkCleanupFns.push(() => link.removeEventListener('click', onLinkClick));
    });

    // 外側タップで閉じる
    const onDocumentClick = (e: MouseEvent) => {
      const { toggle, nav } = getMenuElements();
      if (!toggle || !nav) return;
      if (!nav.classList.contains('is-open')) return;

      const path = typeof e.composedPath === 'function' ? e.composedPath() : [];
      const clickedInNav = path.length > 0 ? path.includes(nav) : nav.contains(e.target as Node);
      const clickedToggle =
        path.length > 0 ? path.includes(toggle) : toggle.contains(e.target as Node);
      if (!clickedInNav && !clickedToggle) {
        closeMenu();
      }
    };
    document.addEventListener('click', onDocumentClick);

    // Esc キーで閉じる + Tab フォーカストラップ（モバイルメニュー開放中）
    const onDocumentKeyDown = (e: KeyboardEvent) => {
      const { toggle, nav } = getMenuElements();
      if (!toggle || !nav) return;
      if (!nav.classList.contains('is-open')) return;

      if (e.key === 'Escape') {
        closeMenu();
        toggle.focus();
        return;
      }

      const focusable = [toggle, ...Array.from(nav.querySelectorAll<HTMLElement>('a[href]'))];
      trapFocus(e, focusable);
    };
    document.addEventListener('keydown', onDocumentKeyDown);

    _cleanupMenuListeners = () => {
      toggle.removeEventListener('click', onToggleClick);
      document.removeEventListener('click', onDocumentClick);
      document.removeEventListener('keydown', onDocumentKeyDown);
      linkCleanupFns.forEach((cleanup) => cleanup());
    };
  }

  // ── 下スクロールで隠す・上スクロールで表示 ──
  // AbortController でページ遷移ごとに旧リスナーを解除（蓄積防止）
  let _scrollAbort: AbortController | null = null;

  function initHideOnScroll() {
    const header = document.querySelector<HTMLElement>('.site-header');
    if (!header) return;
    _scrollAbort?.abort();
    _scrollAbort = new AbortController();
    let lastY = window.scrollY;
    window.addEventListener(
      'scroll',
      () => {
        // メニュー開放中はヘッダーを隠さない（lastY は更新して閉じた後のデルタを安定させる）
        if (header.classList.contains('is-menu-open')) {
          lastY = window.scrollY;
          return;
        }
        const y = window.scrollY;
        if (y < HEADER_HIDE_THRESHOLD_PX) {
          header.classList.remove('is-hidden');
        } else if (y > lastY + HEADER_SCROLL_DELTA_PX) {
          header.classList.add('is-hidden');
        } else if (y < lastY - HEADER_SCROLL_DELTA_PX) {
          header.classList.remove('is-hidden');
        }
        lastY = y;
      },
      { passive: true, signal: _scrollAbort.signal }
    );
  }
  type HeaderWindow = Window & { __siteHeaderBindingsInstalled?: boolean };
  const headerWindow = window as HeaderWindow;
  if (!headerWindow.__siteHeaderBindingsInstalled) {
    headerWindow.__siteHeaderBindingsInstalled = true;

    document.addEventListener('astro:page-load', initMobileMenu);
    document.addEventListener('astro:after-swap', initMobileMenu);
    document.addEventListener('ui:close-overlays', closeMenu);

    // View Transitions でページが切り替わったらメニューを閉じる
    document.addEventListener('astro:before-preparation', closeMenu);
    // back/forward ナビゲーション後もメニューが残らないように
    document.addEventListener('astro:after-swap', closeMenu);

    document.addEventListener('astro:page-load', initHideOnScroll);

    // VT 前にヘッダーを強制表示（is-hidden のまま snapshot が撮られると
    // 新ページで header がポップインして見えるため、transition なしで瞬時に戻す）
    document.addEventListener('astro:before-preparation', () => {
      const header = document.querySelector<HTMLElement>('.site-header');
      if (!header || !header.classList.contains('is-hidden')) return;
      header.style.transition = 'none';
      header.classList.remove('is-hidden');
      void header.offsetHeight; // reflow を強制
      requestAnimationFrame(() => {
        header.style.transition = '';
      });
    });
  }
</script>
