---
import { withBase } from '../utils/withBase';
---

<div class="scroll-progress" id="scroll-progress" aria-hidden="true">
  <img
    class="scroll-progress-tuna"
    src={withBase('images/tuna.png')}
    alt=""
    width="22"
    height="22"
  />
</div>

<script>
  let prevScrollY = 0;
  let ticking = false;
  let vw = window.innerWidth;

  function update() {
    ticking = false;
    const bar = document.getElementById('scroll-progress');
    if (!bar) return;

    const scrolled = window.scrollY;
    const total = document.documentElement.scrollHeight - window.innerHeight;
    const ratio = total > 0 ? scrolled / total : 0;

    // バー: scaleX で幅制御（GPU 合成のみ）
    bar.style.setProperty('--sp', String(ratio));

    // マグロ: translateX で移動 + scaleX で向き（GPU 合成のみ）
    const tuna = bar.querySelector<HTMLElement>('.scroll-progress-tuna');
    if (tuna) {
      const dir = scrolled >= prevScrollY ? -1 : 1;
      const x = ratio * (vw - 22);
      tuna.style.transform = `translateX(${x}px) scaleX(${dir})`;
    }
    prevScrollY = scrolled;
  }

  function onScroll() {
    if (!ticking) {
      requestAnimationFrame(update);
      ticking = true;
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener(
    'resize',
    () => {
      vw = window.innerWidth;
    },
    { passive: true }
  );

  document.addEventListener('astro:page-load', () => {
    prevScrollY = 0;
    vw = window.innerWidth;
    update();
  });
</script>
