---
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../utils/withBase';
import { EXTERNAL_LINKS, IMAGE_DIMENSIONS } from '../utils/constants';
import { buildLinks, PURCHASE_LINK_ENTRIES } from '../utils/types';
import TunaTank from './TunaTank.astro';
import StoreButtonGroup from './StoreButtonGroup.astro';
import TrialLinks from './TrialLinks.astro';

interface Props {
  releasedWork: CollectionEntry<'works'>;
  comingWork: CollectionEntry<'works'>;
}

const { releasedWork: rw, comingWork: cw } = Astro.props;

const rwLinks = buildLinks(rw.data.platformLinks, PURCHASE_LINK_ENTRIES);
---

<section class="dual-hero">
  <TunaTank
    triggerSelector=".dual-hero-panel a"
    goldSpawnRate={0.4}
    fishes={[
      { dir: 'r', top: '12%', dur: '20s', delay: '0s', size: 32 },
      { dir: 'l', top: '50%', dur: '26s', delay: '-8s', size: 48 },
      { dir: 'r', top: '78%', dur: '16s', delay: '-3s', size: 28 },
      { dir: 'l', top: '30%', dur: '32s', delay: '-14s', size: 56 },
      { dir: 'r', top: '88%', dur: '22s', delay: '-10s', size: 40 },
      { dir: 'l', top: '65%', dur: '28s', delay: '-5s', size: 52, gold: true }
    ]}
  />

  <div class="dual-hero-inner container">
    <!-- 左: 今すぐ遊ぶ -->
    <div class="dual-hero-panel">
      <div class="hero-banner-eyebrow">
        <span class="hero-banner-tag">今すぐ遊ぶ</span>
        {rw.data.isR18 && <span class="badge badge--r18">R18</span>}
      </div>

      <a class="dual-hero-cover-link" href={withBase(`works/${rw.slug}/`)} data-astro-prefetch>
        <img
          class="dual-hero-cover"
          src={rw.data.images.cover}
          alt={`${rw.data.title} cover`}
          width={IMAGE_DIMENSIONS.dualHero.width}
          height={IMAGE_DIMENSIONS.dualHero.height}
          fetchpriority="high"
          loading="eager"
        />
      </a>

      <h2 class="dual-hero-title">{rw.data.title}</h2>
      <p class="hero-banner-catch line-clamp-3">{rw.data.catch}</p>

      {
        rw.data.sellingPoints && rw.data.sellingPoints.length > 0 && (
          <ul class="selling-points">
            {rw.data.sellingPoints.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        )
      }

      {
        rwLinks.length > 0 && (
          <div class="hero-banner-cta">
            <StoreButtonGroup links={rwLinks} location="dual_hero_released" />
          </div>
        )
      }

      <div class="hero-banner-sub">
        <TrialLinks trialLinks={rw.data.trialLinks} location="dual_hero_released" />
        <a class="hero-banner-detail-link" href={withBase(`works/${rw.slug}/`)}
          >詳細を見る <span class="hero-detail-arrow">→</span></a
        >
      </div>
    </div>

    <!-- 区切り線 -->
    <div class="dual-hero-divider" aria-hidden="true"></div>

    <!-- 右: 次回作を追う -->
    <div class="dual-hero-panel dual-hero-panel--upcoming">
      <div class="hero-banner-eyebrow">
        <span class="hero-banner-tag dual-hero-tag--upcoming">次回作を追う</span>
        {cw.data.isR18 && <span class="badge badge--r18">R18</span>}
      </div>

      <a class="dual-hero-cover-link" href={withBase(`works/${cw.slug}/`)} data-astro-prefetch>
        <img
          class="dual-hero-cover dual-hero-cover--upcoming"
          src={cw.data.images.cover}
          alt={`${cw.data.title} cover`}
          width={IMAGE_DIMENSIONS.dualHero.width}
          height={IMAGE_DIMENSIONS.dualHero.height}
          loading="lazy"
        />
      </a>

      <h2 class="dual-hero-title">{cw.data.title}</h2>
      <p class="hero-banner-catch line-clamp-3">{cw.data.catch}</p>

      <span class="dual-hero-status-badge">近日公開</span>

      <div class="dual-hero-cta-group">
        <a class="button" href={withBase(`works/${cw.slug}/`)} data-astro-prefetch
          >詳細・進捗を見る</a
        >
        <a
          class="button button--cien"
          href={EXTERNAL_LINKS.cien}
          target="_blank"
          rel="noopener noreferrer"
          data-ga-event="cien_click"
          data-ga-location="dual_hero_upcoming">Ci-en でフォロー ↗</a
        >
      </div>

      <a class="hero-banner-detail-link" href={withBase('news/')}
        >開発ログを見る <span class="hero-detail-arrow">→</span></a
      >
    </div>
  </div>
</section>
