---
import { EA_INPUT_SHAKE_MS } from '../utils/constants';

interface Props {
  password: string;
  downloadUrl: string;
  cienUrl?: string;
}

const { password, downloadUrl, cienUrl } = Astro.props;
// 軽度の難読化: パスワードは HTML ソースに平文で露出させない
const encodedPw = btoa(encodeURIComponent(password));
---

<div class="ea-wrapper">
  <p class="ea-hint">Ci-en で配布した合言葉を入力してください</p>
  {
    cienUrl && (
      <a href={cienUrl} class="ea-cien-link" target="_blank" rel="noopener noreferrer">
        合言葉を入手する →
      </a>
    )
  }
  <div class="ea-row">
    <input
      type="text"
      class="ea-input"
      placeholder="合言葉を入力"
      aria-label="合言葉"
      aria-describedby="ea-error"
      autocomplete="off"
      autocorrect="off"
      autocapitalize="off"
      spellcheck="false"
    />
    <button class="ea-submit" type="button">確認</button>
  </div>
  <p class="ea-error" id="ea-error" role="alert" hidden>合言葉が違います</p>

  <!-- ダウンロードボタン: 合言葉が正解するまで非活性 -->
  <a
    class="ea-download"
    aria-disabled="true"
    tabindex="-1"
    aria-label="先行体験版をダウンロード（合言葉を入力してください）"
  >
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
      <polyline points="7 10 12 15 17 10"></polyline>
      <line x1="12" y1="15" x2="12" y2="3"></line>
    </svg>
    <span>先行体験版をダウンロード</span>
  </a>
</div>

<script define:vars={{ encodedPw, downloadUrl, EA_INPUT_SHAKE_MS }}>
  (function () {
    const wrapper = document.currentScript
      ? document.currentScript.previousElementSibling
      : document.querySelector('.ea-wrapper');
    if (!wrapper) return;

    const input = wrapper.querySelector('.ea-input');
    const submit = wrapper.querySelector('.ea-submit');
    const error = wrapper.querySelector('.ea-error');
    const dlBtn = wrapper.querySelector('.ea-download');

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') submit.click();
    });

    submit.addEventListener('click', () => {
      error.hidden = true;

      const val = input.value.trim().replace(/[\u3000\s]/g, '');
      let match = false;
      try {
        match = btoa(encodeURIComponent(val)) === encodedPw;
      } catch (_) {}

      if (match) {
        // 正解: ダウンロードボタンを活性化
        input.removeAttribute('aria-invalid');
        dlBtn.setAttribute('href', downloadUrl);
        dlBtn.setAttribute('aria-disabled', 'false');
        dlBtn.removeAttribute('tabindex');
        dlBtn.setAttribute('aria-label', '先行体験版をダウンロード');
        dlBtn.classList.add('ea-download--active');
        // 入力欄・確認ボタンを無効化
        input.disabled = true;
        submit.disabled = true;
        dlBtn.focus();
      } else {
        input.setAttribute('aria-invalid', 'true');
        error.hidden = false;
        input.classList.add('ea-input--shake');
        setTimeout(() => input.classList.remove('ea-input--shake'), EA_INPUT_SHAKE_MS);
        input.select();
      }
    });
  })();
</script>

<style>
  .ea-wrapper {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ea-hint {
    font-size: var(--fs-sm);
    color: var(--ink-dim);
    margin: 0;
    line-height: 1.5;
  }

  .ea-cien-link {
    font-size: var(--fs-sm);
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity var(--dur-quick) ease;
  }

  .ea-cien-link:hover {
    opacity: 0.75;
  }

  .ea-row {
    display: flex;
    gap: 6px;
  }

  .ea-input {
    flex: 1;
    min-width: 0;
    padding: 7px 10px;
    min-height: var(--touch-min);
    font-family: inherit;
    font-size: var(--fs-body-sm);
    background: var(--bg);
    color: var(--ink);
    border: 1px solid var(--stroke);
    border-radius: var(--radius-sm);
    outline: none;
    transition:
      border-color var(--dur-fast) ease,
      box-shadow var(--dur-fast) ease;
  }

  .ea-input:focus {
    border-color: #1e8a52;
    box-shadow: 0 0 0 2px rgba(30, 138, 82, 0.15);
  }

  .ea-input:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ea-submit {
    flex-shrink: 0;
    padding: 7px 14px;
    min-height: var(--touch-min);
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: var(--radius-sm);
    font-family: inherit;
    font-size: var(--fs-ui);
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition:
      background var(--dur-fast) ease,
      opacity var(--dur-fast) ease;
  }

  .ea-submit:hover {
    background: var(--accent-2);
  }

  .ea-submit:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .ea-error {
    font-size: var(--fs-sm);
    color: #d93025;
    margin: 0;
  }

  /* ダウンロードボタン */
  .ea-download {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 14px;
    background: var(--bg-2);
    color: var(--ink-dim);
    border: 1px dashed var(--stroke);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--fs-body-sm);
    font-weight: 600;
    text-align: center;
    cursor: not-allowed;
    pointer-events: none;
    transition:
      background var(--dur-quick) ease,
      color var(--dur-quick) ease,
      border var(--dur-quick) ease,
      transform var(--dur-normal) var(--easing),
      box-shadow var(--dur-normal) ease;
  }

  .ea-download--active {
    background: #1e8a52;
    color: #fff;
    border: 1px solid #1e8a52;
    cursor: pointer;
    pointer-events: auto;
  }

  .ea-download--active:hover {
    background: #177a47;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(30, 138, 82, 0.32);
  }

  .ea-download--active:active {
    transform: translateY(0);
    box-shadow: 0 1px 4px rgba(30, 138, 82, 0.18);
  }

  @keyframes ea-shake {
    0%,
    100% {
      transform: translateX(0);
    }
    20% {
      transform: translateX(-6px);
    }
    40% {
      transform: translateX(6px);
    }
    60% {
      transform: translateX(-4px);
    }
    80% {
      transform: translateX(4px);
    }
  }

  .ea-input--shake {
    animation: ea-shake 0.45s ease;
  }
</style>
