---
interface Props {
  message: string;
  href?: string;
  storageKey: string;
}

const { message, href, storageKey } = Astro.props;
---

<div class="announcement-bar" id="announcement-bar" data-storage-key={storageKey}>
  <div class="container announcement-bar-inner">
    {href
      ? <a class="announcement-bar-text" href={href} target="_blank" rel="noopener noreferrer">{message}</a>
      : <span class="announcement-bar-text">{message}</span>
    }
    <button class="announcement-bar-close" aria-label="閉じる">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
</div>

<script>
  function initAnnouncementBar() {
    const bar = document.getElementById('announcement-bar') as HTMLElement | null;
    if (!bar || (bar as any)._barInited) return;
    (bar as any)._barInited = true;

    const key = bar.dataset.storageKey!;

    try {
      if (localStorage.getItem(key)) { bar.remove(); return; }
    } catch (e) {}

    bar.querySelector('.announcement-bar-close')?.addEventListener('click', () => {
      try { localStorage.setItem(key, '1'); } catch (e) {}
      bar.classList.add('is-hiding');
      // transitionend の代わりに setTimeout で確実に除去
      setTimeout(() => bar.remove(), 350);
    });
  }

  document.addEventListener('astro:page-load', initAnnouncementBar);
</script>
