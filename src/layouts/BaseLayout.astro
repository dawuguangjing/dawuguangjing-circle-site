---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import Seo from '../components/Seo.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import BackToTop from '../components/BackToTop.astro';
import AgeGateOverlay from '../components/AgeGateOverlay.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import { AGE_GATE_STORAGE_KEY, AGE_GATE_TTL_MS, ANNOUNCEMENT, GA4_ID, THEME_STORAGE_KEY } from '../utils/constants';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: string;
  noIndex?: boolean;
  hideHeader?: boolean;
  hideFooter?: boolean;
  disableAgeGate?: boolean;
  jsonLd?: Record<string, unknown>;
  publishedTime?: Date;
}

const {
  title,
  description,
  image,
  type,
  noIndex = false,
  hideHeader = false,
  hideFooter = false,
  disableAgeGate = false,
  jsonLd,
  publishedTime
} = Astro.props;
const base = import.meta.env.BASE_URL;
const ageKey = AGE_GATE_STORAGE_KEY;
const ageTtl = AGE_GATE_TTL_MS;
const themeKey = THEME_STORAGE_KEY;
const ga4Id = GA4_ID;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    {/* 年齢確認済みなら <html> に age-verified クラスを付与（レンダリング前に同期実行してフラッシュを防ぐ） */}
    {/* ダークモード初期化（レンダリング前に同期実行してフラッシュを防ぐ） */}
    <script is:inline define:vars={{ themeKey }}>
      (function() {
        // スクロール位置の復元を有効化（back/forward で一覧ページの位置を保持）
        if ('scrollRestoration' in history) history.scrollRestoration = 'auto';

        try {
          var saved = localStorage.getItem(themeKey);
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (saved === 'dark' || (!saved && prefersDark)) {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        } catch(e) {}
      })();
      // View Transitions 後にも再適用
      document.addEventListener('astro:after-swap', function() {
        try {
          var saved = localStorage.getItem(themeKey);
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (saved === 'dark' || (!saved && prefersDark)) {
            document.documentElement.setAttribute('data-theme', 'dark');
          } else {
            document.documentElement.removeAttribute('data-theme');
          }
        } catch(e) {}
      });
    </script>
    {!disableAgeGate && (
      <script is:inline define:vars={{ ageKey }}>
        function _checkAge() {
          try {
            var _saved = Number(localStorage.getItem(ageKey) || 0);
            if (_saved <= Date.now()) _saved = Number(sessionStorage.getItem(ageKey) || 0);
            if (_saved > Date.now()) document.documentElement.classList.add('age-verified');
          } catch(e) {}
        }
        // 初回レンダリング前に同期実行（フラッシュ防止）
        _checkAge();
        // View Transitions でページが差し替わるたびに再チェック
        // （Astroは遷移時に <html> の class をリセットするため）
        document.addEventListener('astro:after-swap', _checkAge);
      </script>
    )}
    <ViewTransitions />
    <!-- Google tag (gtag.js) -->
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
    <script is:inline define:vars={{ ga4Id }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', ga4Id);
    </script>
    <Seo title={title} description={description} image={image} type={type} noIndex={noIndex} jsonLd={jsonLd} publishedTime={publishedTime} />
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <link rel="alternate" type="application/rss+xml" title="ダウグアングジング 開発ログ" href={`${base}rss.xml`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;600;700&display=swap"
      onload="this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>
  </head>
  <body>
    <a class="skip-link" href="#main-content">メインコンテンツへスキップ</a>
    <div class="route-progress" id="route-progress" aria-hidden="true">
      <span class="route-progress-bar"></span>
    </div>

    {/* コンテンツは常にレンダリングされる（クローラーがインデックス可能） */}
    {!hideHeader && ANNOUNCEMENT && (
      <AnnouncementBar
        message={ANNOUNCEMENT.message}
        href={ANNOUNCEMENT.href}
        storageKey={`announce_${ANNOUNCEMENT.id}`}
      />
    )}
    {!hideHeader && <SiteHeader />}
    <main id="main-content"><slot /></main>
    {!hideFooter && <SiteFooter />}
    <BackToTop />

    {/* 年齢確認オーバーレイは DOM 末尾に配置（fixed overlay のため視覚的位置は不変）
        → Googlebot が本文コンテンツを先に読むためスニペットに年齢確認文が出にくくなる */}
    {!disableAgeGate && <AgeGateOverlay ageKey={ageKey} ageTtl={ageTtl} />}

    {!disableAgeGate && (
      <noscript>
        <div class="noscript-block" data-nosnippet>
          <p>このサイトは現在のブラウザ設定では表示できません。</p>
          <p>設定を変更するか、別のブラウザからアクセスしてください。</p>
        </div>
      </noscript>
    )}

    <script>
      import { startRouteProgress, bumpRouteProgress, finishRouteProgress } from '../scripts/route-progress.ts';
      import '../scripts/animations.ts';
      import '../scripts/context-nav.ts';
      import { ensureScrollLockController, resetBodyScrollLocks } from '../scripts/scroll-lock.ts';
      import { closeTransientUi, initGlobalOverlayClose } from '../scripts/overlay-close.ts';
      import { initImgSkeleton } from '../scripts/img-skeleton.ts';
      import { initShareCopy, initNativeShare } from '../scripts/share-copy.ts';
      import { initGa4EventTracking, sendGa4VirtualPv } from '../scripts/ga4-events.ts';

      ensureScrollLockController();

      document.addEventListener('astro:page-load', initGlobalOverlayClose);

      // ── VIEW TRANSITIONS LIFECYCLE ──────────────────────────────────────────
      let _initedBySwap = false;
      document.addEventListener('astro:before-preparation', () => {
        closeTransientUi();
        resetBodyScrollLocks();
        startRouteProgress();
      });
      document.addEventListener('astro:after-swap', () => {
        _initedBySwap = true;
        document.documentElement.classList.add('is-client-nav');
        closeTransientUi();
        resetBodyScrollLocks();
        bumpRouteProgress(0.92);
        initImgSkeleton();
        sendGa4VirtualPv();
      });
      document.addEventListener('astro:page-load', () => {
        if (!_initedBySwap) {
          document.documentElement.classList.remove('is-client-nav');
          initImgSkeleton();
        } else {
          requestAnimationFrame(() => {
            document.documentElement.classList.remove('is-client-nav');
          });
        }
        _initedBySwap = false;
        finishRouteProgress();
      });

      document.addEventListener('astro:page-load', initShareCopy);
      document.addEventListener('astro:page-load', initNativeShare);
      initGa4EventTracking();
    </script>
  </body>
</html>
