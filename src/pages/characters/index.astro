---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../utils/withBase';
import { SITE_NAME, ANIM_BASE_DELAY, ANIM_STAGGER } from '../../utils/constants';

const characters = (await getCollection('characters')).sort(
  (a, b) => a.data.order - b.data.order
);

// 登場作品フィルター用: キャラに紐づく作品のスラッグ→タイトルマップを構築
const works = await getCollection('works');
const workMap = new Map(works.map((w) => [w.slug, w.data.title]));
const uniqueWorkSlugs = [...new Set(
  characters.map((c) => c.data.workSlug).filter(Boolean)
)];
const filterWorks = uniqueWorkSlugs.map((slug) => ({ slug, title: workMap.get(slug) ?? slug }));
---

<BaseLayout
  title={`キャラクター | ${SITE_NAME}`}
  description="ダウグアングジング作品に登場するキャラクターのプロフィール一覧です。"
>
  <div class="page-content" data-list-context="characters">
    <div class="container section">
      <div class="section-header" data-anim>
        <h1 class="section-title">キャラクター</h1>
      </div>

      {filterWorks.length > 1 && (
        <div class="filter-bar" id="char-filter" role="group" aria-label="登場作品でフィルター">
          <button class="filter-chip is-active" data-work="all" aria-pressed="true">すべて</button>
          {filterWorks.map((w) => (
            <button class="filter-chip" data-work={w.slug} aria-pressed="false">{w.title}</button>
          ))}
        </div>
      )}

      <div class="gallery-sort" role="group" aria-label="並び替え">
        <button class="filter-chip is-active" data-char-sort="order">登場順</button>
        <button class="filter-chip" data-char-sort="name">名前順</button>
      </div>
      <div class="list-state-summary" id="characters-state-summary" aria-live="polite">
        <p class="list-state-summary-text" id="characters-state-text">現在条件: すべて</p>
        <button class="list-state-summary-clear" id="characters-state-clear" type="button" hidden>条件を解除</button>
      </div>

      <div class="char-list-grid" id="char-list-grid">
        {characters.map((char, i) => (
          <a
            class="char-list-card"
            href={withBase(`characters/${char.slug}/`)}
            data-anim
            data-work={char.data.workSlug}
            data-order={String(char.data.order)}
            data-name={char.data.name}
            style={`--anim-delay: ${ANIM_BASE_DELAY + i * ANIM_STAGGER}s; --char-color: ${char.data.color}`}
          >
            <div class="char-list-img-wrap">
              <img
                class="char-list-img"
                src={char.data.cover}
                alt={char.data.name}
                sizes="(max-width: 480px) calc(50vw - 18px), (max-width: 1100px) calc(33vw - 28px), 260px"
                width="300"
                height="400"
                loading={i === 0 ? 'eager' : 'lazy'}
                fetchpriority={i === 0 ? 'high' : undefined}
              />
              <div class="char-list-overlay">
                <span class="char-list-view">プロフィールを見る</span>
              </div>
            </div>
            <div class="char-list-body">
              <p class="char-list-reading">{char.data.nameReading}</p>
              <h2 class="char-list-name">{char.data.name}</h2>
              <p class="char-list-personality">{char.data.personality}</p>
              <!-- タッチデバイスでも CTA を認識できるよう常時表示 -->
              <span class="char-list-cta" aria-hidden="true">プロフィールを見る →</span>
            </div>
            <div class="char-list-accent" aria-hidden="true"></div>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
.char-list-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 20px;
}

.char-list-card {
  position: relative;
  display: flex;
  flex-direction: column;
  background: var(--panel);
  border: 1px solid var(--stroke);
  border-radius: var(--radius-lg);
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  box-shadow: var(--shadow);
  transition: border-color 0.25s ease, transform 0.3s var(--easing), box-shadow 0.3s ease;
}

.char-list-card:hover {
  border-color: var(--char-color, var(--accent));
  transform: translateY(-5px);
  box-shadow: 0 12px 28px rgba(0, 0, 0, 0.12);
}

.char-list-img-wrap {
  position: relative;
  aspect-ratio: 3 / 4;
  overflow: hidden;
  background: var(--bg);
}

.char-list-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s var(--easing);
}

.char-list-card:hover .char-list-img {
  transform: scale(1.05);
}

.char-list-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 20px;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.char-list-card:hover .char-list-overlay {
  opacity: 1;
}

.char-list-view {
  color: #fff;
  font-size: 0.82rem;
  font-weight: 600;
  padding: 6px 16px;
  border: 1.5px solid rgba(255, 255, 255, 0.7);
  border-radius: 4px;
  letter-spacing: 0.04em;
}

.char-list-body {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  flex: 1;
}

.char-list-reading {
  font-size: 0.72rem;
  color: var(--ink-dim);
  margin: 0;
  letter-spacing: 0.05em;
}

.char-list-name {
  font-size: 1.1rem;
  font-weight: 700;
  margin: 0;
  color: var(--char-color, var(--accent));
  letter-spacing: 0.03em;
}

.char-list-personality {
  font-size: 0.78rem;
  color: var(--ink-dim);
  margin: 4px 0 0;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* タッチデバイス向け常時表示 CTA */
.char-list-cta {
  font-size: 0.75rem;
  color: var(--char-color, var(--accent));
  font-weight: 600;
  letter-spacing: 0.03em;
  margin-top: auto;
  padding-top: 10px;
}

/* 下部のカラーアクセントバー */
.char-list-accent {
  height: 3px;
  background: var(--char-color, var(--accent));
  opacity: 0;
  transition: opacity 0.25s ease;
}

.char-list-card:hover .char-list-accent {
  opacity: 1;
}

@media (max-width: 480px) {
  .char-list-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
}
</style>

<script>
  const charChips = Array.from(document.querySelectorAll<HTMLButtonElement>('#char-filter .filter-chip'));
  const charCards = Array.from(document.querySelectorAll<HTMLElement>('#char-list-grid .char-list-card'));
  const sortBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-char-sort]'));
  const charGrid = document.getElementById('char-list-grid');
  const validSorts = new Set(['order', 'name']);
  const validWorks = new Set(['all', ...charChips.map((c) => c.dataset.work ?? '').filter(Boolean)]);
  const stateText = document.getElementById('characters-state-text');
  const stateClear = document.getElementById('characters-state-clear') as HTMLButtonElement | null;
  const workLabelMap = new Map(
    charChips.map((chip) => [chip.dataset.work ?? '', (chip.textContent ?? '').trim()])
  );
  const sortLabelMap = new Map(
    sortBtns.map((btn) => [btn.dataset.charSort ?? '', (btn.textContent ?? '').trim()])
  );

  function getActiveWork() {
    const active = charChips.find((c) => c.classList.contains('is-active'))?.dataset.work;
    return validWorks.has(active ?? '') ? active! : 'all';
  }

  function getActiveSort() {
    const active = sortBtns.find((b) => b.classList.contains('is-active'))?.dataset.charSort;
    return validSorts.has(active ?? '') ? active! : 'order';
  }

  function syncStateToUrl(work = getActiveWork(), sort = getActiveSort()) {
    const url = new URL(window.location.href);
    if (work === 'all') {
      url.searchParams.delete('work');
    } else {
      url.searchParams.set('work', work);
    }
    if (sort === 'order') {
      url.searchParams.delete('sort');
    } else {
      url.searchParams.set('sort', sort);
    }
    history.replaceState(null, '', url.toString());
  }

  function updateStateSummary(work = getActiveWork(), sort = getActiveSort()) {
    if (!stateText || !stateClear) return;
    const parts: string[] = [];
    if (work !== 'all') {
      parts.push(`作品: ${workLabelMap.get(work) ?? work}`);
    }
    if (sort !== 'order') {
      parts.push(`並び順: ${sortLabelMap.get(sort) ?? sort}`);
    }
    if (parts.length === 0) {
      stateText.textContent = '現在条件: すべて';
      stateClear.hidden = true;
    } else {
      stateText.textContent = `現在条件: ${parts.join(' ・ ')}`;
      stateClear.hidden = false;
    }
  }

  function applyWorkFilter(work: string, updateUrl = true) {
    const resolvedWork = validWorks.has(work) ? work : 'all';
    charChips.forEach((c) => {
      const isActive = (c.dataset.work ?? '') === resolvedWork;
      c.classList.toggle('is-active', isActive);
      c.setAttribute('aria-pressed', String(isActive));
    });

    let idx = 0;
    charCards.forEach((card) => {
      const show = resolvedWork === 'all' || card.dataset.work === resolvedWork;
      if (show) {
        card.style.display = '';
        card.classList.remove('is-visible');
        card.style.setProperty('--anim-delay', `${idx * 0.05}s`);
        void card.offsetWidth;
        card.classList.add('is-visible');
        idx++;
      } else {
        card.style.display = 'none';
      }
    });

    const sort = getActiveSort();
    updateStateSummary(resolvedWork, sort);
    if (updateUrl) syncStateToUrl(resolvedWork, sort);
  }

  function applyCharSort(sort: string, updateUrl = true) {
    const resolvedSort = validSorts.has(sort) ? sort : 'order';
    sortBtns.forEach((b) => b.classList.toggle('is-active', b.dataset.charSort === resolvedSort));
    if (!charGrid) return;

    const sorted = [...charCards].sort((a, b) => {
      if (resolvedSort === 'name') return (a.dataset.name ?? '').localeCompare(b.dataset.name ?? '', 'ja');
      return Number(a.dataset.order) - Number(b.dataset.order);
    });
    sorted.forEach((el, i) => {
      el.style.setProperty('--anim-delay', `${i * 0.05}s`);
      el.classList.remove('is-visible');
      charGrid.appendChild(el);
      void el.offsetWidth;
      if (el.style.display !== 'none') el.classList.add('is-visible');
    });

    const work = getActiveWork();
    updateStateSummary(work, resolvedSort);
    if (updateUrl) syncStateToUrl(work, resolvedSort);
  }

  charChips.forEach((chip) => {
    chip.addEventListener('click', () => {
      applyWorkFilter(chip.dataset.work ?? 'all');
    });
  });

  sortBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      applyCharSort(btn.dataset.charSort ?? 'order');
    });
  });
  stateClear?.addEventListener('click', () => {
    const defaultSortBtn = sortBtns.find((btn) => btn.dataset.charSort === 'order');
    if (defaultSortBtn && !defaultSortBtn.classList.contains('is-active')) {
      defaultSortBtn.click();
    }
    const allWorkChip = charChips.find((chip) => chip.dataset.work === 'all');
    if (allWorkChip && !allWorkChip.classList.contains('is-active')) {
      allWorkChip.click();
    } else {
      updateStateSummary();
    }
  });

  // 初期化: URL パラメーターから状態を復元
  const params = new URL(window.location.href).searchParams;
  applyCharSort(params.get('sort') ?? 'order', false);
  applyWorkFilter(params.get('work') ?? 'all', false);
  syncStateToUrl();
  updateStateSummary();
</script>
