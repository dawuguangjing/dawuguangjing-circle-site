---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GalleryCard from '../../components/GalleryCard.astro';
import { getSortedGallery } from '../../utils/collections';
import { SITE_NAME, ANIM_STAGGER } from '../../utils/constants';

const galleries = await getSortedGallery();
---

<BaseLayout
  title={`ギャラリー | ${SITE_NAME}`}
  description="サークルが制作したCG集・イラスト集の一覧です。"
>
  <div class="page-content" data-list-context="gallery">
    <section class="section container">
      <div class="section-header" data-anim>
        <h1 class="section-title">ギャラリー</h1>
        <span class="section-count muted">{galleries.length}件</span>
      </div>
      <div class="gallery-sort" role="group" aria-label="並び替え">
        <button class="filter-chip is-active" data-sort="newest">新着順</button>
        <button class="filter-chip" data-sort="oldest">古い順</button>
        <button class="filter-chip" data-sort="title">タイトル順</button>
      </div>
      <div class="list-state-summary" id="gallery-state-summary" aria-live="polite">
        <p class="list-state-summary-text" id="gallery-state-text">現在条件: すべて</p>
        <button class="list-state-summary-clear" id="gallery-state-clear" type="button" hidden>並び順をリセット</button>
      </div>
      {galleries.length > 0 ? (
        <div class="gallery-album-grid" id="gallery-grid">
          {galleries.map((entry, i) => (
            <div
              data-anim
              style={`--anim-delay: ${i * ANIM_STAGGER}s`}
              data-release={entry.data.releaseDate.getTime().toString()}
              data-title={entry.data.title}
            >
              <GalleryCard
                slug={entry.slug}
                title={entry.data.title}
                cover={entry.data.cover}
                isR18={entry.data.isR18}
                imageCount={entry.resolvedImageCount}
                previewImages={entry.data.images}
                loading={i === 0 ? 'eager' : 'lazy'}
                fetchpriority={i === 0 ? 'high' : undefined}
              />
            </div>
          ))}
        </div>
      ) : (
        <p class="muted">現在公開中のギャラリーはありません。</p>
      )}
    </section>
  </div>
</BaseLayout>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.gallery-sort [data-sort]');
  const grid = document.getElementById('gallery-grid');
  const validSorts = new Set(['newest', 'oldest', 'title']);
  const stateText = document.getElementById('gallery-state-text');
  const stateClear = document.getElementById('gallery-state-clear') as HTMLButtonElement | null;
  const sortLabelMap = new Map(
    Array.from(chips).map((chip) => [chip.dataset.sort ?? '', (chip.textContent ?? '').trim()])
  );

  function updateSortSummary(sort: string) {
    if (!stateText || !stateClear) return;
    if (sort === 'newest') {
      stateText.textContent = '現在条件: すべて';
      stateClear.hidden = true;
      return;
    }
    stateText.textContent = `現在条件: 並び順 ${sortLabelMap.get(sort) ?? sort}`;
    stateClear.hidden = false;
  }

  function applySort(sort: string, updateUrl = true) {
    const resolvedSort = validSorts.has(sort) ? sort : 'newest';
    chips.forEach((c) => c.classList.toggle('is-active', c.dataset.sort === resolvedSort));
    if (!grid) return;
    const items = Array.from(grid.children) as HTMLElement[];
    const sorted = [...items].sort((a, b) => {
      if (resolvedSort === 'newest') return Number(b.dataset.release) - Number(a.dataset.release);
      if (resolvedSort === 'oldest') return Number(a.dataset.release) - Number(b.dataset.release);
      if (resolvedSort === 'title') return (a.dataset.title ?? '').localeCompare(b.dataset.title ?? '', 'ja');
      return 0;
    });
    sorted.forEach((el) => grid.appendChild(el));
    updateSortSummary(resolvedSort);

    if (updateUrl) {
      const url = new URL(window.location.href);
      if (resolvedSort === 'newest') {
        url.searchParams.delete('sort');
      } else {
        url.searchParams.set('sort', resolvedSort);
      }
      history.replaceState(null, '', url.toString());
    }
  }

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      applySort(chip.dataset.sort ?? 'newest');
    });
  });
  stateClear?.addEventListener('click', () => {
    applySort('newest');
  });

  // 初期化: URL パラメーターから状態を復元
  const urlSort = new URL(window.location.href).searchParams.get('sort');
  if (urlSort) applySort(urlSort);
  else updateSortSummary('newest');
</script>
