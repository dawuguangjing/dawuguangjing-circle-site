---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GalleryCard from '../../components/GalleryCard.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import FilterSheet from '../../components/FilterSheet.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getSortedGallery } from '../../utils/collections';
import { SITE_NAME, animDelay } from '../../utils/constants';
import { imageLoadingProps } from '../../utils/format';

const galleries = await getSortedGallery();
---

<BaseLayout
  title={`ギャラリー | ${SITE_NAME}`}
  description="サークルが制作したCG集・イラスト集の一覧です。"
>
  <Breadcrumb crumbs={[{ label: 'ギャラリー' }]} />
  <div class="page-content" data-list-context="gallery">
    <section class="section container">
      <SectionHeader title="ギャラリー" as="h1">
        <span class="section-count muted">{galleries.length}件</span>
      </SectionHeader>
      <FilterSheet
        filterBarId="gallery-filter-bar"
        triggerText="並び替え"
        ariaLabel="並び替え"
        stateId="gallery"
        clearText="並び順をリセット"
      >
        <button class="filter-chip is-active" data-sort="newest">新着順</button>
        <button class="filter-chip" data-sort="oldest">古い順</button>
        <button class="filter-chip" data-sort="title">タイトル順</button>
      </FilterSheet>
      {
        galleries.length > 0 ? (
          <div class="gallery-album-grid grid-stretch-items" id="gallery-grid">
            {galleries.map((entry, i) => (
              <div
                data-anim
                style={`--anim-delay: ${animDelay(i)}`}
                data-release-date={entry.data.releaseDate.getTime().toString()}
                data-title={entry.data.title}
              >
                <GalleryCard
                  slug={entry.slug}
                  title={entry.data.title}
                  cover={entry.data.cover}
                  isR18={entry.data.isR18}
                  imageCount={entry.resolvedImageCount}
                  previewImages={entry.data.images}
                  {...imageLoadingProps(i)}
                />
              </div>
            ))}
          </div>
        ) : (
          <p class="muted">現在公開中のギャラリーはありません。</p>
        )
      }
    </section>
  </div>
</BaseLayout>

<script>
  import { initPageFilterSheet } from '../../scripts/filter-sheet';
  import { setupListFilter } from '../../scripts/list-filter';
  import { dateTitleSort } from '../../scripts/sort-helpers';

  initPageFilterSheet('gallery-filter-bar', 'gallery-filter-sheet');

  setupListFilter({
    stateId: 'gallery',
    gridSelector: '#gallery-grid',
    itemSelector: '#gallery-grid > [data-anim]',
    animateDelay: false,
    dimensions: [
      {
        type: 'sort',
        paramName: 'sort',
        defaultValue: 'newest',
        chipSelector: '#gallery-filter-bar [data-sort]',
        chipDataKey: 'sort',
        sortFn: dateTitleSort()
      }
    ]
  });
</script>
