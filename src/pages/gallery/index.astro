---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GalleryCard from '../../components/GalleryCard.astro';
import { getSortedGallery } from '../../utils/collections';
import { SITE_NAME, ANIM_STAGGER } from '../../utils/constants';

const galleries = await getSortedGallery();
---

<BaseLayout
  title={`ギャラリー | ${SITE_NAME}`}
  description="サークルが制作したCG集・イラスト集の一覧です。"
>
  <div class="page-content">
    <section class="section container">
      <div class="section-header" data-anim>
        <h1 class="section-title">ギャラリー</h1>
        <span class="section-count muted">{galleries.length}件</span>
      </div>
      <div class="gallery-sort" role="group" aria-label="並び替え">
        <button class="filter-chip is-active" data-sort="newest">新着順</button>
        <button class="filter-chip" data-sort="oldest">古い順</button>
        <button class="filter-chip" data-sort="title">タイトル順</button>
      </div>
      {galleries.length > 0 ? (
        <div class="gallery-album-grid" id="gallery-grid">
          {galleries.map((entry, i) => (
            <div
              data-anim
              style={`--anim-delay: ${i * ANIM_STAGGER}s`}
              data-release={entry.data.releaseDate.getTime().toString()}
              data-title={entry.data.title}
            >
              <GalleryCard
                slug={entry.slug}
                title={entry.data.title}
                cover={entry.data.cover}
                isR18={entry.data.isR18}
                releaseDate={entry.data.releaseDate}
                imageCount={entry.resolvedImageCount}
                loading={i === 0 ? 'eager' : 'lazy'}
                fetchpriority={i === 0 ? 'high' : undefined}
              />
            </div>
          ))}
        </div>
      ) : (
        <p class="muted">現在公開中のギャラリーはありません。</p>
      )}
    </section>
  </div>
</BaseLayout>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.gallery-sort [data-sort]');
  const grid = document.getElementById('gallery-grid');

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => c.classList.toggle('is-active', c === chip));
      if (!grid) return;
      const items = Array.from(grid.children) as HTMLElement[];
      const sort = chip.dataset.sort!;
      const sorted = [...items].sort((a, b) => {
        if (sort === 'newest') return Number(b.dataset.release) - Number(a.dataset.release);
        if (sort === 'oldest') return Number(a.dataset.release) - Number(b.dataset.release);
        if (sort === 'title') return (a.dataset.title ?? '').localeCompare(b.dataset.title ?? '', 'ja');
        return 0;
      });
      sorted.forEach((el) => grid.appendChild(el));
    });
  });
</script>
