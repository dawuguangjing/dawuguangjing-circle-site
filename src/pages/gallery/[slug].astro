---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Lightbox from '../../components/Lightbox.astro';
import { withBase } from '../../utils/withBase';
import { formatDate } from '../../utils/format';
import { SITE_NAME } from '../../utils/constants';
import { getWorkIndex, resolveImageCount, getSortedGallery, buildPrevNext, getCharactersByGallery } from '../../utils/collections';
import Breadcrumb from '../../components/Breadcrumb.astro';
import StoreSidebar from '../../components/StoreSidebar.astro';
import StoreButtonGroup from '../../components/StoreButtonGroup.astro';
import ArticlePagination from '../../components/ArticlePagination.astro';
import FabPurchase from '../../components/FabPurchase.astro';
import { buildLinks, PURCHASE_LINK_ENTRIES, TRIAL_LINK_ENTRIES } from '../../utils/types';

export async function getStaticPaths() {
  return buildPrevNext(await getSortedGallery());
}

const { entry, prev, next } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;

const imageCount = resolveImageCount(data);
const videoCount = data.videos?.length ?? 0;
const hasMedia = data.images.length > 0 || videoCount > 0;
const hasStoreLinks = !!(data.platformLinks?.fanza || data.platformLinks?.dlsite);

const workIndex = await getWorkIndex();
const relatedWorks = (data.relatedWorkSlugs ?? []).flatMap((slug) => {
  const w = workIndex.get(slug);
  return w ? [w] : [];
});

// ギャラリー自身にリンクがない場合、関連作品のリンクを fallback として使用
const relatedWorkLinks = hasStoreLinks ? [] : relatedWorks.flatMap((w) =>
  buildLinks(w.data.platformLinks, PURCHASE_LINK_ENTRIES)
);

// 関連作品の体験版リンク
const relatedWorkTrialLinks = relatedWorks.flatMap((w) =>
  buildLinks(w.data.trialLinks ?? {}, TRIAL_LINK_ENTRIES)
);

const hasAnyCta = hasStoreLinks || relatedWorkLinks.length > 0 || relatedWorkTrialLinks.length > 0;

const relatedCharacters = await getCharactersByGallery(entry.slug);
const sidebarChars = relatedCharacters.map((c) => ({
  slug: c.slug,
  name: c.data.name,
  cover: c.data.cover,
}));

const galleryPurchaseLinks = hasStoreLinks
  ? buildLinks(data.platformLinks!, PURCHASE_LINK_ENTRIES)
  : relatedWorkLinks;
---

<BaseLayout
  title={`${data.title} | ${SITE_NAME}`}
  description={data.description}
  image={data.cover}
>
  <div class="page-content">
    <div class="container">
      <Breadcrumb crumbs={[
        { label: 'ギャラリー', href: withBase('gallery/') },
        { label: data.title },
      ]} />
    </div>
    <section class="section container">
      <div class="section-header" data-anim>
        <h1 class="section-title detail-title">{data.title}</h1>
        <div class="gallery-header-meta">
          {hasMedia && (
            <span class="gallery-count-badge">
              {imageCount > 0 && `${imageCount}枚`}{imageCount > 0 && videoCount > 0 && ' · '}{videoCount > 0 && `動画${videoCount}本`}
            </span>
          )}
        </div>
      </div>

      <div class="detail-layout">
        <!-- Main Column -->
        <div class="detail-main">
          <!-- Description -->
          {entry.body?.trim() && (
            <div class="detail-block" data-anim>
              <Content />
            </div>
          )}

          <!-- Media Grid (images + videos) -->
          {hasMedia && (
            <div class="gallery-detail-grid" data-anim style="--anim-delay: 0.1s">
              {data.images.map((img, i) => (
                <div
                  class="gallery-detail-item"
                  data-lightbox-src={img}
                  data-lightbox-type="image"
                  data-lightbox-alt={`${data.title} ${i + 1}`}
                >
                  <img
                    src={img}
                    alt={`${data.title} ${i + 1}`}
                    loading="lazy"
                    width="400"
                    height="300"
                  />
                </div>
              ))}
              {(data.videos ?? []).map((videoUrl, vi) => (
                <div
                  class="gallery-detail-item gallery-detail-item--video"
                  data-lightbox-src={videoUrl}
                  data-lightbox-type="video"
                  tabindex="0"
                  role="button"
                  aria-label={`${data.title} 動画 ${vi + 1} を開く`}
                >
                  <video
                    src={videoUrl}
                    muted
                    loop
                    playsinline
                    preload="metadata"
                    poster={data.cover}
                    class="gallery-detail-video"
                  ></video>
                  <div class="gallery-detail-play-icon" aria-hidden="true">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <StoreSidebar
          isR18={data.isR18}
          trialLinks={relatedWorkTrialLinks}
          purchaseLinks={galleryPurchaseLinks}
          characters={sidebarChars}
          location="gallery_detail"
          animDelay="0.15s"
        >
          <Fragment slot="before-trial">
            <h3>情報</h3>
            <table class="spec-table">
              <tbody>
                <tr>
                  <td>リリース日</td>
                  <td>{formatDate(data.releaseDate)}</td>
                </tr>
                <tr>
                  <td>収録枚数</td>
                  <td>{imageCount}枚</td>
                </tr>
                {videoCount > 0 && (
                  <tr>
                    <td>動画本数</td>
                    <td>{videoCount}本</td>
                  </tr>
                )}
              </tbody>
            </table>
          </Fragment>

          <Fragment slot="after-chars">
            {relatedWorks.length > 0 && (
              <div class="sidebar-divider">
                <h3>関連作品</h3>
                {relatedWorks.map((work) => {
                  const wPurchaseLinks = buildLinks(work.data.platformLinks, PURCHASE_LINK_ENTRIES);
                  const wTrialLinks = buildLinks(work.data.trialLinks ?? {}, TRIAL_LINK_ENTRIES);
                  return (
                    <div class="related-work-card">
                      <a class="related-work-card-link-wrap" href={withBase(`works/${work.slug}/`)}>
                        <img
                          src={withBase(work.data.images.cover)}
                          alt={`${work.data.title} cover`}
                          width="240"
                          height="160"
                          loading="lazy"
                        />
                        <div class="related-work-card-body">
                          <p class="related-work-card-title">{work.data.title}</p>
                          {work.data.shortDescription && (
                            <p class="related-work-card-desc">{work.data.shortDescription}</p>
                          )}
                          <span class="section-link related-work-card-detail">詳細を見る →</span>
                        </div>
                      </a>
                      {(wTrialLinks.length > 0 || wPurchaseLinks.length > 0) && (
                        <div class="related-work-card-cta">
                          {wTrialLinks.length > 0 && (
                            <StoreButtonGroup links={wTrialLinks} trial location="gallery_related_work" />
                          )}
                          {wPurchaseLinks.length > 0 && (
                            <StoreButtonGroup links={wPurchaseLinks} location="gallery_related_work" />
                          )}
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>
            )}
          </Fragment>
        </StoreSidebar>
      </div>
    </section>

    <Lightbox itemSelector=".gallery-detail-item" />

    <section class="container section--compact">
      <div class="back-link">
        <a class="section-link" href={withBase('gallery/')} data-back-context data-back-context-key="gallery">← ギャラリー一覧へ戻る</a>
      </div>

      <ArticlePagination
        prev={prev}
        next={next}
        basePath="gallery/"
        prevLabel="前のギャラリー"
        nextLabel="次のギャラリー"
        ariaLabel="前後のギャラリーへ"
      />
    </section>
  </div>

  <!-- ホバー／フォーカス／ビューポート内で動画プレビューを再生 -->
  <script>
    const prefersReducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!prefersReducedMotion) {
      const isTouch = matchMedia('(hover: none)').matches;

      document.querySelectorAll<HTMLElement>('.gallery-detail-item--video').forEach((item) => {
        const video = item.querySelector('video');
        if (!video) return;
        const play  = () => video.play().catch(() => {});
        const reset = () => { video.pause(); video.currentTime = 0; };

        if (isTouch) {
          const io = new IntersectionObserver(([e]) => {
            e.isIntersecting ? play() : reset();
          }, { threshold: 0.5 });
          io.observe(item);
        } else {
          item.addEventListener('mouseenter', play);
          item.addEventListener('mouseleave', reset);
        }

        item.addEventListener('focusin',  play);
        item.addEventListener('focusout', reset);
      });
    }
  </script>
  {hasAnyCta && <FabPurchase targetId="purchase-section" />}

</BaseLayout>
