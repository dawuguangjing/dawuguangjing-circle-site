---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Lightbox from '../../components/Lightbox.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../utils/withBase';
import { formatDate } from '../../utils/format';
import { SITE_NAME } from '../../utils/constants';
import { getWorkIndex, resolveImageCount } from '../../utils/collections';

export async function getStaticPaths() {
  const galleries = await getCollection('gallery');
  return galleries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;

const imageCount = resolveImageCount(data);

const workIndex = await getWorkIndex();
const relatedWorks = (data.relatedWorkSlugs ?? []).flatMap((slug) => {
  const w = workIndex.get(slug);
  return w ? [w] : [];
});
---

<BaseLayout
  title={`${data.title} | ${SITE_NAME}`}
  description={data.description}
  image={data.cover}
>
  <div class="page-content">
    <section class="section container">
      <div class="section-header" data-anim>
        <h1 class="section-title detail-title">{data.title}</h1>
        <span class="muted" style="font-size:0.8rem;white-space:nowrap;">{formatDate(data.releaseDate)}</span>
      </div>

      <div class="detail-layout">
        <!-- Main Column -->
        <div class="detail-main">
          <!-- Description -->
          {entry.body?.trim() && (
            <div class="detail-block" data-anim>
              <Content />
            </div>
          )}

          <!-- Image Grid -->
          {data.images.length > 0 && (
            <div class="gallery-detail-grid" data-anim style="--anim-delay: 0.1s">
              {data.images.map((img, i) => (
                <div class="gallery-detail-item">
                  <img
                    src={img}
                    alt={`${data.title} ${i + 1}`}
                    loading="lazy"
                    width="400"
                    height="300"
                  />
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <div class="store-sidebar" data-anim="slide-right" style="--anim-delay: 0.15s">
          <!-- Age Rating -->
          <div>
            {data.isR18
              ? <span class="badge badge--r18">R18 作品</span>
              : <span class="badge">全年齢</span>
            }
          </div>

          <!-- Info Table -->
          <h3>情報</h3>
          <table class="spec-table">
            <tbody>
              <tr>
                <td>リリース日</td>
                <td>{formatDate(data.releaseDate)}</td>
              </tr>
              <tr>
                <td>収録枚数</td>
                <td>{imageCount}枚</td>
              </tr>
            </tbody>
          </table>

          <!-- Purchase Links -->
          {data.platformLinks && (data.platformLinks.fanza || data.platformLinks.dlsite) && (
            <>
              <h3>購入する</h3>
              <div class="store-button-group">
                {data.platformLinks.fanza && (
                  <a
                    class="store-button"
                    href={data.platformLinks.fanza}
                    target="_blank"
                    rel="noopener noreferrer"
                    data-store="fanza"
                  >
                    <span>FANZA で購入</span>
                    <span class="arrow">→</span>
                  </a>
                )}
                {data.platformLinks.dlsite && (
                  <a
                    class="store-button"
                    href={data.platformLinks.dlsite}
                    target="_blank"
                    rel="noopener noreferrer"
                    data-store="dlsite"
                  >
                    <span>DLsite で購入</span>
                    <span class="arrow">→</span>
                  </a>
                )}
              </div>
            </>
          )}

          <!-- Related Works -->
          {relatedWorks.length > 0 && (
            <div class="sidebar-divider">
              <h3>関連作品</h3>
              {relatedWorks.map((work) => (
                <a class="related-work-card" href={withBase(`works/${work.slug}/`)}>
                  <img
                    src={withBase(work.data.images.cover)}
                    alt={`${work.data.title} cover`}
                    width="240"
                    height="160"
                    loading="lazy"
                  />
                  <div class="related-work-card-body">
                    <p class="related-work-card-title">{work.data.title}</p>
                    {work.data.shortDescription && (
                      <p class="related-work-card-desc">{work.data.shortDescription}</p>
                    )}
                    <span class="section-link related-work-card-link">詳細を見る →</span>
                  </div>
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>

    <Lightbox imageSelector=".gallery-detail-item img" />

    <section class="container section--compact">
      <div class="back-link">
        <a class="section-link" href={withBase('gallery/')}>← ギャラリー一覧へ戻る</a>
      </div>
    </section>
  </div>

</BaseLayout>
