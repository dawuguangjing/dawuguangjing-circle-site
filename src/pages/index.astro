---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkCard from '../components/WorkCard.astro';
import NewsCard from '../components/NewsCard.astro';
import GalleryCard from '../components/GalleryCard.astro';
import HeroBanner from '../components/HeroBanner.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../utils/withBase';
import { HOME_NEWS_LIMIT, HOME_GALLERY_LIMIT, SITE_NAME, ANIM_BASE_DELAY, ANIM_STAGGER } from '../utils/constants';
import { getSortedWorks, getSortedNews, getSortedGallery, extractFirstImageUrl } from '../utils/collections';

const allWorks = await getSortedWorks();
const news = (await getSortedNews()).slice(0, HOME_NEWS_LIMIT);
const galleries = (await getSortedGallery()).slice(0, HOME_GALLERY_LIMIT);
const characters = (await getCollection('characters')).sort(
  (a, b) => a.data.order - b.data.order
);
const now = new Date();
const heroWork = allWorks.find(w => w.data.releaseDate <= now) ?? null;
---

<BaseLayout
  title={SITE_NAME}
  description="ダウグアングジング公式サイト。成人向け同人ゲーム『従順審査』『従順審査2』の作品情報、開発ログ、キャラクター紹介を掲載。"
>
  <div class="page-content">
    {heroWork && (
      <HeroBanner
        slug={heroWork.slug}
        title={heroWork.data.title}
        catch={heroWork.data.catch}
        cover={heroWork.data.images.cover}
        isR18={heroWork.data.isR18}
        platformLinks={heroWork.data.platformLinks}
        trialLinks={heroWork.data.trialLinks}
        sellingPoints={heroWork.data.sellingPoints}
      />
    )}

    <section class="section container">
      <div class="section-header" data-anim>
        <h2 class="section-title">作品</h2>
        <a class="section-link" href={withBase('works/')}>すべて見る →</a>
      </div>
      <div class="works-grid">
        {allWorks.map((entry, i) => (
          <div data-anim style={`--anim-delay: ${ANIM_BASE_DELAY + i * ANIM_STAGGER}s`}>
            <WorkCard
              slug={entry.slug}
              title={entry.data.title}
              cover={entry.data.images.cover}
              description={entry.data.shortDescription}
              releaseDate={entry.data.releaseDate}
              isR18={entry.data.isR18}
              loading={i === 0 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : undefined}
            />
          </div>
        ))}
      </div>
    </section>

    {characters.length > 0 && (
      <section class="section container">
        <div class="section-header" data-anim>
          <h2 class="section-title">キャラクター</h2>
          <a class="section-link" href={withBase('characters/')}>すべて見る →</a>
        </div>
        <div class="home-char-grid">
          {characters.map((char, i) => (
            <a
              class="home-char-card"
              href={withBase(`characters/${char.slug}/`)}
              data-anim
              style={`--anim-delay: ${ANIM_BASE_DELAY + i * ANIM_STAGGER}s; --char-color: ${char.data.color}`}
            >
              <div class="home-char-img-wrap">
                <img
                  src={char.data.cover}
                  alt={char.data.name}
                  width="160"
                  height="213"
                  loading="lazy"
                />
                <div class="home-char-overlay" aria-hidden="true">
                  <span class="home-char-view">プロフィールを見る</span>
                </div>
              </div>
              <div class="home-char-body">
                <p class="home-char-reading">{char.data.nameReading}</p>
                <h3 class="home-char-name">{char.data.name}</h3>
              </div>
              <div class="home-char-accent" aria-hidden="true"></div>
            </a>
          ))}
        </div>
      </section>
    )}

    {galleries.length > 0 && (
      <section class="section container">
        <div class="section-header" data-anim>
          <h2 class="section-title">ギャラリー</h2>
          <a class="section-link" href={withBase('gallery/')}>すべて見る →</a>
        </div>
        <div class="gallery-album-grid">
          {galleries.map((entry, i) => (
            <div data-anim style={`--anim-delay: ${ANIM_BASE_DELAY + i * ANIM_STAGGER}s`}>
              <GalleryCard
                slug={entry.slug}
                title={entry.data.title}
                cover={entry.data.cover}
                isR18={entry.data.isR18}
                releaseDate={entry.data.releaseDate}
                imageCount={entry.resolvedImageCount}
                previewImages={entry.data.images}
              />
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="section container">
      <div class="section-header" data-anim>
        <h2 class="section-title">開発ログ</h2>
        <a class="section-link" href={withBase('news/')}>すべて見る →</a>
      </div>
      <div class="news-grid">
        {news.map((entry, i) => (
          <div data-anim style={`--anim-delay: ${ANIM_BASE_DELAY + i * ANIM_STAGGER}s`}>
            <NewsCard
              slug={entry.slug}
              title={entry.data.title}
              date={entry.data.date}
              category={entry.data.category}
              thumbnail={entry.data.eyecatch ?? extractFirstImageUrl(entry.body)}
            />
          </div>
        ))}
        <div data-anim style={`--anim-delay: ${ANIM_BASE_DELAY + news.length * ANIM_STAGGER}s`}>
          <a class="news-card-more" href={withBase('news/')}>
            <svg class="news-card-more-icon" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <line x1="10" y1="9" x2="8" y2="9"/>
            </svg>
            <span class="news-card-more-label">過去の記事をすべて見る</span>
            <span class="news-card-more-cta">
              一覧ページへ
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
.home-char-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(130px, 160px));
  gap: 14px;
}

.home-char-card {
  position: relative;
  display: flex;
  flex-direction: column;
  background: var(--panel);
  border: 1px solid var(--stroke);
  border-radius: var(--radius-lg);
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  box-shadow: var(--shadow);
  transition: border-color 0.25s ease, transform 0.3s var(--easing), box-shadow 0.3s ease;
}

.home-char-img-wrap {
  position: relative;
  aspect-ratio: 3 / 4;
  overflow: hidden;
  background: var(--bg);
}

.home-char-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 14px;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.home-char-view {
  color: #fff;
  font-size: 0.72rem;
  font-weight: 600;
  padding: 4px 12px;
  border: 1.5px solid rgba(255, 255, 255, 0.7);
  border-radius: 4px;
  letter-spacing: 0.04em;
  white-space: nowrap;
}

.home-char-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s var(--easing);
}

.home-char-body {
  padding: 10px 12px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.home-char-reading {
  font-size: 0.65rem;
  color: var(--ink-dim);
  margin: 0;
  letter-spacing: 0.05em;
}

.home-char-name {
  font-size: 0.88rem;
  font-weight: 700;
  margin: 0;
  color: var(--char-color, var(--accent));
  letter-spacing: 0.02em;
}

.home-char-accent {
  height: 3px;
  background: var(--char-color, var(--accent));
  opacity: 0;
  transition: opacity 0.25s ease;
}

@media (hover: hover) and (pointer: fine) {
  .home-char-card:hover {
    border-color: var(--char-color, var(--accent));
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12);
  }

  .home-char-card:hover .home-char-overlay {
    opacity: 1;
  }

  .home-char-card:hover .home-char-img-wrap img {
    transform: scale(1.05);
  }

  .home-char-card:hover .home-char-accent {
    opacity: 1;
  }
}
</style>
