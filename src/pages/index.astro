---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkCard from '../components/WorkCard.astro';
import NewsCard from '../components/NewsCard.astro';
import GalleryCard from '../components/GalleryCard.astro';
import HeroBanner from '../components/HeroBanner.astro';
import { withBase } from '../utils/withBase';
import { HOME_NEWS_LIMIT, HOME_GALLERY_LIMIT, SITE_NAME } from '../utils/constants';
import { getSortedWorks, getSortedNews, getSortedGallery, extractFirstImageUrl } from '../utils/collections';

const allWorks = await getSortedWorks();
const news = (await getSortedNews()).slice(0, HOME_NEWS_LIMIT);
const galleries = (await getSortedGallery()).slice(0, HOME_GALLERY_LIMIT);
const heroWork = allWorks[0];
---

<BaseLayout
  title={SITE_NAME}
  description="作品・告知・外部リンクをまとめた公式ハブ。"
>
  <div class="page-content">
    {heroWork && (
      <HeroBanner
        slug={heroWork.slug}
        title={heroWork.data.title}
        catch={heroWork.data.catch}
        cover={heroWork.data.images.cover}
        isR18={heroWork.data.isR18}
        platformLinks={heroWork.data.platformLinks}
        sellingPoints={heroWork.data.sellingPoints}
      />
    )}

    <section class="section container">
      <div class="section-header">
        <h2 class="section-title">作品</h2>
        <a class="section-link" href={withBase('works/')}>すべて見る →</a>
      </div>
      <div class="works-grid">
        {allWorks.map((entry) => (
          <WorkCard
            slug={entry.slug}
            title={entry.data.title}
            cover={entry.data.images.cover}
            description={entry.data.shortDescription}
            releaseDate={entry.data.releaseDate}
            isR18={entry.data.isR18}
          />
        ))}
      </div>
    </section>

    {galleries.length > 0 && (
      <section class="section container">
        <div class="section-header">
          <h2 class="section-title">ギャラリー</h2>
          <a class="section-link" href={withBase('gallery/')}>すべて見る →</a>
        </div>
        <div class="gallery-album-grid">
          {galleries.map((entry) => (
            <GalleryCard
              slug={entry.slug}
              title={entry.data.title}
              cover={entry.data.cover}
              isR18={entry.data.isR18}
              releaseDate={entry.data.releaseDate}
              imageCount={entry.data.imageCount ?? entry.data.images.length}
            />
          ))}
        </div>
      </section>
    )}

    <section class="section container">
      <div class="section-header">
        <h2 class="section-title">開発ログ</h2>
        <a class="section-link" href={withBase('news/')}>すべて見る →</a>
      </div>
      <div class="grid">
        {news.map((entry) => (
          <NewsCard
            slug={entry.slug}
            title={entry.data.title}
            date={entry.data.date}
            category={entry.data.category}
            thumbnail={entry.data.eyecatch ?? extractFirstImageUrl(entry.body)}
          />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
