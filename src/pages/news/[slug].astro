---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedWorks from '../../components/RelatedWorks.astro';
import { withBase } from '../../utils/withBase';
import { formatDate } from '../../utils/format';
import { categoryLabels } from '../../utils/labels';
import { getWorkIndex, getSortedNews, buildPrevNext } from '../../utils/collections';
import { buildArticleSchema } from '../../utils/schema';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ScrollProgress from '../../components/ScrollProgress.astro';
import ShareBar from '../../components/ShareBar.astro';

export async function getStaticPaths() {
  return buildPrevNext(await getSortedNews());
}

const { entry, prev, next } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;

const workIndex = await getWorkIndex();
const articleJsonLd = buildArticleSchema({
  headline: data.title,
  datePublished: data.date,
  image: data.eyecatch,
});

// 読了時間（日本語 約500字/分）
const readMin = Math.max(1, Math.round(entry.body.replace(/\s+/g, '').length / 500));
---

<BaseLayout title={`${data.title} | 開発ログ`} description={data.title} image={data.eyecatch} type="article" publishedTime={data.date} jsonLd={articleJsonLd}>
  <ScrollProgress />
  <div class="page-content">
    <div class="container">
      <Breadcrumb crumbs={[
        { label: '開発ログ', href: withBase('news/') },
        { label: data.title },
      ]} />
    </div>
    <section class="section container">
      <div class="article-layout">
        <div class="article-layout-main">
          <article class="article">
            <div class="article-header" data-anim>
              <a href={withBase(`news/?category=${data.category}`)} class={`badge badge--${data.category}`} title="このカテゴリの記事を見る">{categoryLabels[data.category] ?? data.category}</a>
              <time class="article-date">{formatDate(data.date)}</time>
              <span class="article-read-time">約 {readMin} 分</span>
            </div>
            <h1 class="article-title" data-anim style="--anim-delay: 0.06s">{data.title}</h1>
            <!-- モバイル向け TOC へのジャンプリンク（デスクトップでは aside に表示されるため非表示） -->
            <a class="toc-jump-link" id="toc-jump" href="#toc" hidden>↓ この記事の目次を見る</a>
            <div class="article-body">
              <Content />
            </div>
            {data.relatedWorkSlugs && data.relatedWorkSlugs.length > 0 && (
              <div class="article-related">
                <h3>関連作品</h3>
                <RelatedWorks slugs={data.relatedWorkSlugs} workIndex={workIndex} justifyEnd={true} />
              </div>
            )}
          </article>
          <ShareBar url={Astro.url.href} title={data.title} />
          <div class="back-link">
            <a class="section-link" href={withBase(`news/?category=${data.category}`)} data-back-context data-back-context-key="news">← 開発ログへ戻る</a>
          </div>

          {(prev || next) && (
            <nav class="article-pagination" aria-label="前後の記事へ">
              <div class="article-pagination-prev">
                {prev && (
                  <a class="article-pagination-link" href={withBase(`news/${prev.slug}/`)}>
                    <span class="article-pagination-arrow">←</span>
                    <span class="article-pagination-meta">
                      <span class="article-pagination-label">前の記事</span>
                      <span class="article-pagination-title">{prev.data.title}</span>
                    </span>
                  </a>
                )}
              </div>
              <div class="article-pagination-next">
                {next && (
                  <a class="article-pagination-link article-pagination-link--next" href={withBase(`news/${next.slug}/`)}>
                    <span class="article-pagination-meta">
                      <span class="article-pagination-label">次の記事</span>
                      <span class="article-pagination-title">{next.data.title}</span>
                    </span>
                    <span class="article-pagination-arrow">→</span>
                  </a>
                )}
              </div>
            </nav>
          )}
        </div>
        <aside class="article-layout-aside">
          <nav class="toc" id="toc" hidden aria-label="目次">
            <p class="toc-heading">目次</p>
            <ol class="toc-list" id="toc-list"></ol>
          </nav>
        </aside>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  const toc = document.getElementById('toc');
  const tocList = document.getElementById('toc-list');
  const headings = Array.from(
    document.querySelectorAll<HTMLHeadingElement>('.article-body h2, .article-body h3')
  );

  if (toc && tocList && headings.length >= 2) {
    headings.forEach((h, i) => {
      if (!h.id) h.id = `heading-${i}`;
      const li = document.createElement('li');
      li.className = h.tagName === 'H3' ? 'toc-item toc-item--sub' : 'toc-item';
      const a = document.createElement('a');
      a.href = `#${h.id}`;
      a.textContent = h.textContent ?? '';
      li.appendChild(a);
      tocList.appendChild(li);
    });
    toc.removeAttribute('hidden');
    // モバイル向けジャンプリンクも表示
    document.getElementById('toc-jump')?.removeAttribute('hidden');

    // ── TOCスクロールスパイ ──
    const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('#toc-list a'));
    const spy = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            tocLinks.forEach((a) => {
              a.classList.toggle('is-active', a.getAttribute('href') === `#${id}`);
            });
          }
        });
      },
      { rootMargin: '0px 0px -60% 0px', threshold: 0 }
    );
    headings.forEach((h) => spy.observe(h));
  }
</script>
