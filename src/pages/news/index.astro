---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsCard from '../../components/NewsCard.astro';
import RelatedWorks from '../../components/RelatedWorks.astro';
import { getSortedNews, getWorkIndex, extractFirstImageUrl } from '../../utils/collections';
import { ANIM_BASE_DELAY, ANIM_STAGGER } from '../../utils/constants';
import { categoryLabels } from '../../utils/labels';

const news = await getSortedNews();
const workIndex = await getWorkIndex();
const categories = Object.entries(categoryLabels) as [string, string][];

function extractExcerpt(body: string, maxLen = 100): string {
  const text = body
    .replace(/^#{1,6}\s+.+$/gm, '')
    .replace(/!\[.*?\]\(.*?\)/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[*_`~>#\-|]+/g, '')
    .replace(/\s+/g, ' ')
    .trim();
  return text.length > maxLen ? text.slice(0, maxLen) + '…' : text;
}
---

<BaseLayout title="開発ログ" description="告知、更新、セール情報。">
  <div class="page-content" data-list-context="news">
    <section class="section container">
      <div class="section-header" data-anim>
        <h1 class="section-title">開発ログ</h1>
      </div>

      <div class="filter-chips" id="news-filter" role="group" aria-label="記事フィルター">
        <button class="filter-chip is-active" data-category="all">すべて</button>
        {categories.map(([key, label]) => (
          <button class="filter-chip" data-category={key}>{label}</button>
        ))}
      </div>
      <div class="list-state-summary" id="news-state-summary" aria-live="polite">
        <p class="list-state-summary-text" id="news-state-text">現在条件: すべて</p>
        <button class="list-state-summary-clear" id="news-state-clear" type="button" hidden>条件を解除</button>
      </div>

      <div class="news-grid" id="news-grid">
        {news.map((entry, i) => (
          <div data-anim data-category={entry.data.category} style={`--anim-delay: ${ANIM_BASE_DELAY + i * ANIM_STAGGER}s`}>
            <NewsCard
              slug={entry.slug}
              title={entry.data.title}
              date={entry.data.date}
              category={entry.data.category}
              thumbnail={entry.data.eyecatch ?? extractFirstImageUrl(entry.body)}
              excerpt={extractExcerpt(entry.body)}
              loading={i === 0 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : undefined}
            >
              {entry.data.relatedWorkSlugs && (
                <RelatedWorks slugs={entry.data.relatedWorkSlugs} workIndex={workIndex} />
              )}
            </NewsCard>
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('#news-filter .filter-chip');
  const items = document.querySelectorAll<HTMLElement>('#news-grid [data-category]');
  const validCategories = new Set(['all', ...Array.from(chips).map((c) => c.dataset.category ?? '').filter(Boolean)]);
  const stateText = document.getElementById('news-state-text');
  const stateClear = document.getElementById('news-state-clear') as HTMLButtonElement | null;
  const categoryLabelMap = new Map(
    Array.from(chips).map((chip) => [chip.dataset.category ?? '', (chip.textContent ?? '').trim()])
  );

  function updateCategorySummary(category: string) {
    if (!stateText || !stateClear) return;
    if (category === 'all') {
      stateText.textContent = '現在条件: すべて';
      stateClear.hidden = true;
      return;
    }
    stateText.textContent = `現在条件: ${categoryLabelMap.get(category) ?? category}`;
    stateClear.hidden = false;
  }

  function applyCategory(cat: string, updateUrl = true) {
    const resolvedCat = validCategories.has(cat) ? cat : 'all';
    chips.forEach((chip) => {
      chip.classList.toggle('is-active', chip.dataset.category === resolvedCat);
    });

    let visibleIndex = 0;
    items.forEach((el) => {
      const show = resolvedCat === 'all' || el.dataset.category === resolvedCat;
      if (show) {
        el.style.display = '';
        el.classList.remove('is-visible');
        el.style.setProperty('--anim-delay', `${visibleIndex * 0.06}s`);
        void el.offsetWidth; // force reflow to restart transition
        el.classList.add('is-visible');
        visibleIndex++;
      } else {
        el.style.display = 'none';
      }
    });
    updateCategorySummary(resolvedCat);

    if (updateUrl) {
      const url = new URL(window.location.href);
      if (resolvedCat === 'all') {
        url.searchParams.delete('category');
      } else {
        url.searchParams.set('category', resolvedCat);
      }
      history.replaceState(null, '', url.toString());
    }
  }

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      const cat = chip.dataset.category ?? 'all';
      applyCategory(cat);
    });
  });
  stateClear?.addEventListener('click', () => {
    applyCategory('all');
  });

  // URL の ?category= パラメーターを自動適用（ニュース詳細のタグリンクから遷移した場合）
  const urlCat = new URL(window.location.href).searchParams.get('category');
  if (urlCat) applyCategory(urlCat);
  else updateCategorySummary('all');
</script>
