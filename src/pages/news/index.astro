---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsCard from '../../components/NewsCard.astro';
import RelatedWorks from '../../components/RelatedWorks.astro';
import { getSortedNews, getWorkIndex, extractFirstImageUrl } from '../../utils/collections';
import { ANIM_BASE_DELAY, ANIM_STAGGER } from '../../utils/constants';
import { categoryLabels } from '../../utils/labels';

const news = await getSortedNews();
const workIndex = await getWorkIndex();
const categories = Object.entries(categoryLabels) as [string, string][];
---

<BaseLayout title="開発ログ" description="告知、更新、セール情報。">
  <div class="page-content">
    <section class="section container">
      <div class="section-header" data-anim>
        <h1 class="section-title">開発ログ</h1>
      </div>

      <div class="filter-chips" id="news-filter" role="group" aria-label="記事フィルター">
        <button class="filter-chip is-active" data-category="all">すべて</button>
        {categories.map(([key, label]) => (
          <button class="filter-chip" data-category={key}>{label}</button>
        ))}
      </div>

      <div class="news-grid" id="news-grid">
        {news.map((entry, i) => (
          <div data-anim data-category={entry.data.category} style={`--anim-delay: ${ANIM_BASE_DELAY + i * ANIM_STAGGER}s`}>
            <NewsCard
              slug={entry.slug}
              title={entry.data.title}
              date={entry.data.date}
              category={entry.data.category}
              thumbnail={entry.data.eyecatch ?? extractFirstImageUrl(entry.body)}
              loading={i === 0 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : undefined}
            >
              {entry.data.relatedWorkSlugs && (
                <RelatedWorks slugs={entry.data.relatedWorkSlugs} workIndex={workIndex} />
              )}
            </NewsCard>
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('#news-filter .filter-chip');
  const items = document.querySelectorAll<HTMLElement>('#news-grid [data-category]');

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      const cat = chip.dataset.category!;
      chips.forEach((c) => c.classList.toggle('is-active', c === chip));

      let visibleIndex = 0;
      items.forEach((el) => {
        const show = cat === 'all' || el.dataset.category === cat;
        if (show) {
          el.style.display = '';
          el.classList.remove('is-visible');
          el.style.setProperty('--anim-delay', `${visibleIndex * 0.06}s`);
          void el.offsetWidth; // force reflow to restart transition
          el.classList.add('is-visible');
          visibleIndex++;
        } else {
          el.style.display = 'none';
        }
      });
    });
  });
</script>
