---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { withBase } from '../utils/withBase';
import { animDelay, ANIM_STAGGER, EXTERNAL_LINKS } from '../utils/constants';
---

<BaseLayout
  title="お問い合わせ"
  description="ダウグアングジングへのお問い合わせ窓口。フォームからご質問・ご意見・不具合報告を受け付けています。"
>
  <div class="page-content contact-page">
  <section class="section container">
    <Breadcrumb crumbs={[{ label: 'お問い合わせ' }]} />
    <h1 class="section-title" data-anim>お問い合わせ</h1>
    <p class="section-lead" data-anim style={`--anim-delay: ${ANIM_STAGGER}s`}>
      ご質問・ご意見・不具合報告は、下記フォームよりご連絡ください。
    </p>

    <p class="form-fallback-note" data-anim style={`--anim-delay: ${animDelay(0, 0.06)}`}>
      フォームが表示されない場合は
      <a href="https://docs.google.com/forms/d/e/1FAIpQLSeI3gTEuIA8876IBdE9Ok0Qv8fGi8fe1PicLdpK_YNApfbDjA/viewform" target="_blank" rel="noopener noreferrer">別タブで開く &#8599;</a>
      か、<a href={EXTERNAL_LINKS.cien} target="_blank" rel="noopener noreferrer">Ci-en</a> からもご連絡いただけます。
    </p>

    <div class="form-wrapper" data-anim style={`--anim-delay: ${animDelay(0, 0.06)}`}>
      <div class="form-loading" id="form-loading" role="status" aria-live="polite">
        <div class="form-loading-content" id="form-loading-spinner">
          <img class="form-loading-tuna" src={withBase('images/tuna.png')} alt="" width="40" height="40" />
          <span class="form-loading-text">読み込んでいます…</span>
          <span class="form-loading-hint" id="form-loading-hint" hidden>時間がかかっています…もう少しお待ちください</span>
          <div class="form-loading-slow" id="form-loading-slow" hidden>
            <p class="form-loading-slow-text">読み込みに時間がかかっています。</p>
            <button class="button button--sm" id="form-retry" type="button">再読み込み</button>
            <a
              class="form-direct-link"
              href="https://docs.google.com/forms/d/e/1FAIpQLSeI3gTEuIA8876IBdE9Ok0Qv8fGi8fe1PicLdpK_YNApfbDjA/viewform"
              target="_blank"
              rel="noopener noreferrer"
            >フォームを別タブで開く &#8599;</a>
          </div>
        </div>
      </div>
      <iframe
        data-src="https://docs.google.com/forms/d/e/1FAIpQLSeI3gTEuIA8876IBdE9Ok0Qv8fGi8fe1PicLdpK_YNApfbDjA/viewform?embedded=true"
        width="100%"
        height="800"
        frameborder="0"
        marginheight="0"
        marginwidth="0"
        title="お問い合わせフォーム"
        id="contact-iframe"
      ></iframe>
    </div>
    <script>
      import { FORM_LOAD_TIMEOUT_MS, FORM_OBSERVE_MARGIN } from '../utils/constants';

      function initContactForm() {
        const iframe = document.getElementById('contact-iframe') as HTMLIFrameElement | null;
        const loader = document.getElementById('form-loading');
        const hintEl = document.getElementById('form-loading-hint');
        const slowEl = document.getElementById('form-loading-slow');
        const retryBtn = document.getElementById('form-retry');
        if (!iframe || !loader || !iframe.dataset.src) return;

        let loaded = false;
        let hintTimer: ReturnType<typeof setTimeout> | null = null;
        let slowTimer: ReturnType<typeof setTimeout> | null = null;

        function clearTimers() {
          if (hintTimer) clearTimeout(hintTimer);
          if (slowTimer) clearTimeout(slowTimer);
        }

        function hideLoader() {
          loader!.classList.add('is-hidden');
          clearTimers();
          if (hintEl) hintEl.hidden = true;
          if (slowEl) slowEl.hidden = true;
        }

        function loadIframe() {
          loaded = false;
          clearTimers();
          if (hintEl) hintEl.hidden = true;
          if (slowEl) slowEl.hidden = true;
          loader!.classList.remove('is-hidden');

          iframe!.addEventListener('load', () => {
            loaded = true;
            hideLoader();
          }, { once: true });

          iframe!.src = iframe!.dataset.src!;

          // 読み込みが遅い場合にヒントを表示
          hintTimer = setTimeout(() => {
            if (!loaded && hintEl) hintEl.hidden = false;
          }, FORM_LOAD_TIMEOUT_MS / 3);

          // さらに時間がかかる場合に再読み込み・別タブリンクを表示
          slowTimer = setTimeout(() => {
            if (!loaded && slowEl) slowEl.hidden = false;
          }, FORM_LOAD_TIMEOUT_MS);
        }

        retryBtn?.addEventListener('click', loadIframe);

        const observer = new IntersectionObserver((entries) => {
          if (entries[0].isIntersecting) {
            observer.disconnect();
            loadIframe();
          }
        }, { rootMargin: FORM_OBSERVE_MARGIN });
        observer.observe(iframe);
      }

      document.addEventListener('astro:page-load', initContactForm);
    </script>

    <div class="card card--static" data-anim style={`--anim-delay: ${animDelay(1, 0.06)}`} data-nosnippet>
      <p>補助窓口として、Ci-en からもご連絡いただけます。</p>
      <a class="button button--cien" href={EXTERNAL_LINKS.cien} target="_blank" rel="noopener noreferrer">
        Ci-en を開く &#8599;
      </a>
    </div>
  </section>
  </div>
</BaseLayout>

<style>
  .form-wrapper {
    position: relative;
    border-radius: var(--radius-lg, 12px);
    overflow: hidden;
    background: var(--color-surface, #1a1a2e);
    border: 1px solid var(--color-border, rgba(255,255,255,0.08));
    margin-bottom: 2rem;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
  }

  .form-loading {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    transition: opacity var(--dur-slow) ease;
    z-index: 1;
  }

  .form-loading-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .form-loading-tuna {
    animation: tuna-loading 1.8s ease-in-out infinite;
    opacity: 0.5;
  }

  .form-loading-text {
    color: var(--ink-dim);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
  }

  .form-loading-hint {
    color: var(--ink-dim);
    font-size: 0.78rem;
    opacity: 0.7;
    animation: hint-fade-in 0.4s ease;
  }

  @keyframes hint-fade-in {
    from { opacity: 0; }
    to { opacity: 0.7; }
  }

  @keyframes tuna-loading {
    0%, 100% { transform: translateX(-12px) scaleX(-1); }
    50% { transform: translateX(12px) scaleX(-1); }
  }

  .form-loading.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .form-loading-slow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    animation: hint-fade-in 0.4s ease;
  }

  .form-loading-slow-text {
    color: var(--ink-dim);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    margin: 0;
  }

  .form-wrapper iframe {
    display: block;
    min-height: 800px;
    border: none;
  }

  @media (max-width: 640px) {
    .form-wrapper iframe {
      min-height: 750px;
    }
  }

  @media (max-width: 400px) {
    .form-wrapper iframe {
      min-height: 700px;
    }
  }

  .form-fallback-note {
    font-size: 0.82rem;
    color: var(--ink-dim);
    margin: 0 0 12px;
  }
  .form-fallback-note a {
    color: var(--accent);
    text-decoration: underline;
  }

  .form-direct-link {
    font-size: 0.82rem;
    color: var(--accent);
    text-decoration: underline;
    margin-top: 4px;
  }
</style>
