---
import BaseLayout from '../layouts/BaseLayout.astro';
import { EXTERNAL_LINKS } from '../utils/constants';
---

<BaseLayout
  title="お問い合わせ"
  description="ダウグアングジングへのお問い合わせ窓口。フォームからご質問・ご意見・不具合報告を受け付けています。"
>
  <div class="page-content contact-page">
  <section class="section container">
    <h1 class="section-title" data-anim>お問い合わせ</h1>
    <p class="section-lead" data-anim style="--anim-delay: 0.07s">
      ご質問・ご意見・不具合報告は、下記フォームよりご連絡ください。
    </p>

    <div class="form-wrapper" data-anim style="--anim-delay: 0.14s">
      <div class="form-loading" id="form-loading">読み込んでいます…</div>
      <iframe
        data-src="https://docs.google.com/forms/d/e/1FAIpQLSeI3gTEuIA8876IBdE9Ok0Qv8fGi8fe1PicLdpK_YNApfbDjA/viewform?embedded=true"
        width="100%"
        height="800"
        frameborder="0"
        marginheight="0"
        marginwidth="0"
        title="お問い合わせフォーム"
        id="contact-iframe"
      ></iframe>
    </div>
    <script>
      const iframe = document.getElementById('contact-iframe') as HTMLIFrameElement | null;
      const loader = document.getElementById('form-loading');
      function hideLoader() {
        if (loader && !loader.classList.contains('is-hidden')) {
          loader.classList.add('is-hidden');
        }
      }
      if (iframe && iframe.dataset.src) {
        const observer = new IntersectionObserver((entries) => {
          if (entries[0].isIntersecting) {
            observer.disconnect();
            iframe.addEventListener('load', hideLoader, { once: true });
            iframe.src = iframe.dataset.src!;
            // フォールバック: load が発火しない場合に備え 8 秒後に強制非表示
            setTimeout(hideLoader, 8000);
          }
        }, { rootMargin: '200px' });
        observer.observe(iframe);
      }
    </script>

    <div class="card card--static" data-anim style="--anim-delay: 0.21s" data-nosnippet>
      <p>補助窓口として、Ci-en からもご連絡いただけます。</p>
      <a class="button button--cien" href={EXTERNAL_LINKS.cien} target="_blank" rel="noopener noreferrer">
        Ci-en を開く &#8599;
      </a>
    </div>
  </section>
  </div>
</BaseLayout>

<style>
  .form-wrapper {
    position: relative;
    border-radius: var(--radius-lg, 12px);
    overflow: hidden;
    background: var(--color-surface, #1a1a2e);
    border: 1px solid var(--color-border, rgba(255,255,255,0.08));
    margin-bottom: 2rem;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
  }

  .form-loading {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink-dim);
    font-size: 0.9rem;
    background: linear-gradient(90deg, var(--stroke) 25%, var(--bg) 50%, var(--stroke) 75%);
    background-size: 800px 100%;
    animation: skeleton-shimmer 1.5s ease-in-out infinite;
    transition: opacity 0.3s ease;
    z-index: 1;
  }

  .form-loading.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .form-wrapper iframe {
    display: block;
    min-height: 800px;
    border: none;
  }
</style>
