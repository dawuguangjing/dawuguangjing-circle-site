---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkCard from '../../components/WorkCard.astro';
import { getSortedWorks } from '../../utils/collections';
import { ANIM_BASE_DELAY, ANIM_STAGGER } from '../../utils/constants';

const works = await getSortedWorks();
---

<BaseLayout title="作品一覧" description="公開中の作品と外部リンク。">
  <div class="page-content" data-list-context="works">
    <section class="section container">
      <div class="section-header" data-anim>
        <h1 class="section-title">全作品</h1>
        <span class="muted" id="work-count">{works.length} タイトル</span>
      </div>

      <!-- モバイル: フィルターシート開閉トリガー -->
      <button class="filter-sheet-trigger" id="filter-sheet-trigger" aria-expanded="false" aria-controls="filter-bar">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
        絞り込み
        <span class="filter-sheet-trigger-badge" id="filter-active-badge" hidden>0</span>
      </button>
      <!-- オーバーレイ -->
      <div class="filter-sheet-overlay" id="filter-sheet-overlay" aria-hidden="true"></div>

      <div class="filter-bar" id="filter-bar" role="group" aria-label="作品フィルター（複数選択可・AND条件）">
        <!-- モバイル: シートヘッダー -->
        <div class="filter-sheet-header">
          <span class="filter-sheet-header-title">絞り込み</span>
          <button class="filter-sheet-close" id="filter-sheet-close">閉じる</button>
        </div>
        <button class="filter-chip is-active" data-filter="all" aria-pressed="true">すべて</button>
        <button class="filter-chip" data-filter="r18" aria-pressed="false">R18</button>
        <button class="filter-chip" data-filter="all-ages" aria-pressed="false">全年齢</button>
        <button class="filter-chip" data-filter="windows" aria-pressed="false">Windows</button>
        <button class="filter-chip" data-filter="mac" aria-pressed="false">Mac</button>
        <button class="filter-chip" data-filter="browser" aria-pressed="false">ブラウザ</button>
        <button class="filter-chip" data-filter="ios" aria-pressed="false">iOS</button>
        <button class="filter-chip" data-filter="android" aria-pressed="false">Android</button>
      </div>

      <div class="sort-bar">
        <span class="sort-label">並び順:</span>
        <button class="sort-btn is-active" data-sort="newest">新しい順</button>
        <button class="sort-btn" data-sort="oldest">古い順</button>
        <button class="sort-btn" data-sort="title">タイトル順</button>
      </div>
      <div class="list-state-summary" id="works-state-summary" aria-live="polite">
        <p class="list-state-summary-text" id="works-state-text">現在条件: すべて</p>
        <button class="list-state-summary-clear" id="works-state-clear" type="button" hidden>条件を解除</button>
      </div>

      <div class="works-grid" id="works-grid">
        {works.map((entry, i) => (
          <div
            class="work-filter-item"
            data-anim
            style={`--anim-delay: ${ANIM_BASE_DELAY + 0.04 + i * ANIM_STAGGER}s`}
            data-r18={String(entry.data.isR18)}
            data-windows={String(entry.data.environments.windows)}
            data-mac={String(entry.data.environments.mac)}
            data-browser={String(entry.data.environments.browserPc)}
            data-ios={String(entry.data.environments.ios)}
            data-android={String(entry.data.environments.android)}
            data-release-date={String(entry.data.releaseDate.getTime())}
            data-title={entry.data.title}
          >
            <WorkCard
              slug={entry.slug}
              title={entry.data.title}
              cover={entry.data.images.cover}
              description={entry.data.shortDescription}
              releaseDate={entry.data.releaseDate}
              isR18={entry.data.isR18}
              hasTrial={!!(entry.data.trialLinks?.fanza || entry.data.trialLinks?.dlsite)}
              showEnvironments
              environments={entry.data.environments}
              loading={i === 0 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : undefined}
            />
          </div>
        ))}
      </div>

      <div class="works-empty-state" id="works-empty" aria-live="polite">
        <p>該当する作品がありません</p>
        <button class="button" id="works-filter-reset">フィルターをリセット</button>
      </div>
    </section>
  </div>

  <script>
    // ── フィルターボトムシート（モバイル） ──
    const sheetTrigger = document.getElementById('filter-sheet-trigger');
    const sheetOverlay = document.getElementById('filter-sheet-overlay');
    const sheetClose   = document.getElementById('filter-sheet-close');
    const filterBar    = document.getElementById('filter-bar');
    const activeBadge  = document.getElementById('filter-active-badge');
    const uiWindow = window as Window & {
      lockBodyScroll?: (key: string) => void;
      unlockBodyScroll?: (key: string) => void;
    };

    function openSheet() {
      filterBar?.classList.add('is-open');
      sheetOverlay?.classList.add('is-visible');
      sheetOverlay?.removeAttribute('aria-hidden');
      sheetTrigger?.setAttribute('aria-expanded', 'true');
      if (uiWindow.lockBodyScroll) uiWindow.lockBodyScroll('works-filter-sheet');
      else document.body.style.overflow = 'hidden';
    }
    function closeSheet() {
      filterBar?.classList.remove('is-open');
      sheetOverlay?.classList.remove('is-visible');
      sheetOverlay?.setAttribute('aria-hidden', 'true');
      sheetTrigger?.setAttribute('aria-expanded', 'false');
      if (uiWindow.unlockBodyScroll) uiWindow.unlockBodyScroll('works-filter-sheet');
      else document.body.style.overflow = '';
    }
    sheetTrigger?.addEventListener('click', () => {
      if (filterBar?.classList.contains('is-open')) closeSheet();
      else openSheet();
    });
    sheetOverlay?.addEventListener('click', closeSheet);
    sheetClose?.addEventListener('click', closeSheet);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeSheet();
    });
    document.addEventListener('ui:close-overlays', closeSheet);
    document.addEventListener('astro:before-preparation', closeSheet);

    const chips = Array.from(document.querySelectorAll<HTMLElement>('.filter-chip'));
    const items = Array.from(document.querySelectorAll<HTMLElement>('.work-filter-item'));
    const allChip = chips.find(c => c.dataset.filter === 'all')!;
    const sortBtns = Array.from(document.querySelectorAll<HTMLElement>('.sort-btn'));
    const stateText = document.getElementById('works-state-text');
    const stateClear = document.getElementById('works-state-clear') as HTMLButtonElement | null;
    const grid = document.getElementById('works-grid')!;
    const VALID_SORTS = new Set(['newest', 'oldest', 'title']);
    const filterLabelMap = new Map(
      chips
        .filter((c) => (c.dataset.filter ?? '') !== '' && c.dataset.filter !== 'all')
        .map((c) => [c.dataset.filter!, (c.textContent ?? '').trim() || c.dataset.filter!])
    );
    const sortLabelMap = new Map(
      sortBtns
        .filter((b) => VALID_SORTS.has(b.dataset.sort ?? ''))
        .map((b) => [b.dataset.sort!, (b.textContent ?? '').trim() || b.dataset.sort!])
    );

    // フィルターキー → 表示条件
    const filterTest: Record<string, (el: HTMLElement) => boolean> = {
      'r18':      el => el.dataset.r18      === 'true',
      'all-ages': el => el.dataset.r18      === 'false',
      'windows':  el => el.dataset.windows  === 'true',
      'mac':      el => el.dataset.mac      === 'true',
      'browser':  el => el.dataset.browser  === 'true',
      'ios':      el => el.dataset.ios      === 'true',
      'android':  el => el.dataset.android  === 'true',
    };

    function getActiveFilters() {
      return chips.filter(c => c.classList.contains('is-active') && c.dataset.filter !== 'all')
                  .map(c => c.dataset.filter!);
    }

    function getActiveSort() {
      const active = sortBtns.find((b) => b.classList.contains('is-active'))?.dataset.sort;
      return VALID_SORTS.has(active ?? '') ? active! : 'newest';
    }

    function syncStateToUrl(activeFilters = getActiveFilters()) {
      const url = new URL(window.location.href);
      if (activeFilters.length === 0) {
        url.searchParams.delete('filters');
      } else {
        url.searchParams.set('filters', activeFilters.join(','));
      }
      const sort = getActiveSort();
      if (sort === 'newest') {
        url.searchParams.delete('sort');
      } else {
        url.searchParams.set('sort', sort);
      }
      history.replaceState(null, '', url.toString());
    }

    function updateStateSummary(activeFilters = getActiveFilters(), sort = getActiveSort()) {
      if (!stateText || !stateClear) return;
      const parts: string[] = [];
      if (activeFilters.length > 0) {
        const labels = activeFilters.map((f) => filterLabelMap.get(f) ?? f);
        parts.push(`絞り込み: ${labels.join(' / ')}`);
      }
      if (sort !== 'newest') {
        parts.push(`並び順: ${sortLabelMap.get(sort) ?? sort}`);
      }
      if (parts.length === 0) {
        stateText.textContent = '現在条件: すべて';
        stateClear.hidden = true;
      } else {
        stateText.textContent = `現在条件: ${parts.join(' ・ ')}`;
        stateClear.hidden = false;
      }
    }

    const emptyEl = document.getElementById('works-empty');

    function applyFilters() {
      const active = getActiveFilters();
      let visibleCount = 0;
      items.forEach((el) => {
        // アクティブなフィルターがなければ全件表示、あれば全条件 AND
        const show = active.length === 0 || active.every(f => filterTest[f]?.(el));
        if (show) {
          el.style.display = '';
          el.classList.remove('is-visible');
          el.style.setProperty('--anim-delay', `${visibleCount * 0.06}s`);
          void el.offsetWidth; // force reflow to restart transition
          el.classList.add('is-visible');
          visibleCount++;
        } else {
          el.style.display = 'none';
        }
      });

      // 空状態表示
      emptyEl?.classList.toggle('is-visible', visibleCount === 0);

      // 件数表示更新
      const countEl = document.getElementById('work-count');
      if (countEl) {
        countEl.textContent = active.length === 0
          ? `${items.length} タイトル`
          : `${visibleCount} 件表示中`;
      }
      updateStateSummary(active, getActiveSort());

      // URL に状態を保存（ブックマーク・シェア対応）
      syncStateToUrl(active);

      // トリガーボタンのバッジ更新
      if (activeBadge) {
        if (active.length > 0) {
          activeBadge.textContent = String(active.length);
          activeBadge.removeAttribute('hidden');
          sheetTrigger?.classList.add('has-active');
        } else {
          activeBadge.setAttribute('hidden', '');
          sheetTrigger?.classList.remove('has-active');
        }
      }
    }

    chips.forEach((chip, i) => {
      chip.addEventListener('click', () => {
        if (chip.dataset.filter === 'all') {
          // "すべて" → 他チップをリセットして "すべて" だけオン
          chips.forEach(c => { c.classList.remove('is-active'); c.setAttribute('aria-pressed', 'false'); });
          chip.classList.add('is-active');
          chip.setAttribute('aria-pressed', 'true');
        } else {
          // "すべて" をオフ
          allChip.classList.remove('is-active');
          allChip.setAttribute('aria-pressed', 'false');
          // このチップをトグル
          const next = !chip.classList.contains('is-active');
          chip.classList.toggle('is-active', next);
          chip.setAttribute('aria-pressed', String(next));
          // 何も選択されていなければ "すべて" に戻す
          if (getActiveFilters().length === 0) {
            allChip.classList.add('is-active');
            allChip.setAttribute('aria-pressed', 'true');
          }
        }
        applyFilters();
      });

      // 矢印キーでチップ間を移動
      chip.addEventListener('keydown', (e) => {
        let target: HTMLElement | null = null;
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
          e.preventDefault();
          target = chips[(i + 1) % chips.length];
        } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
          e.preventDefault();
          target = chips[(i - 1 + chips.length) % chips.length];
        }
        target?.focus();
      });
    });

    // フィルターリセットボタン
    document.getElementById('works-filter-reset')?.addEventListener('click', () => {
      allChip.click();
    });
    stateClear?.addEventListener('click', () => {
      const newestBtn = sortBtns.find((b) => b.dataset.sort === 'newest');
      if (newestBtn && !newestBtn.classList.contains('is-active')) {
        newestBtn.click();
      }
      if (getActiveFilters().length > 0 || !allChip.classList.contains('is-active')) {
        allChip.click();
      } else {
        updateStateSummary();
      }
    });

    // 初期化: URL パラメーターから状態を復元
    const url = new URL(window.location.href);
    const urlFilters = url.searchParams.get('filters');
    if (urlFilters) {
      allChip.classList.remove('is-active');
      allChip.setAttribute('aria-pressed', 'false');
      let activeCount = 0;
      urlFilters.split(',').forEach((f) => {
        const chip = chips.find((c) => c.dataset.filter === f);
        if (chip) {
          chip.classList.add('is-active');
          chip.setAttribute('aria-pressed', 'true');
          activeCount++;
        }
      });
      if (activeCount === 0) {
        allChip.classList.add('is-active');
        allChip.setAttribute('aria-pressed', 'true');
      }
    }
    applyFilters();
    sortBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        sortBtns.forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        const sort = btn.dataset.sort;
        const sorted = [...items].sort((a, b) => {
          if (sort === 'title') return (a.dataset.title ?? '').localeCompare(b.dataset.title ?? '', 'ja');
          const da = Number(a.dataset.releaseDate);
          const db = Number(b.dataset.releaseDate);
          return sort === 'oldest' ? da - db : db - da;
        });
        sorted.forEach((el, idx) => {
          el.style.setProperty('--anim-delay', `${idx * 0.05}s`);
          el.classList.remove('is-visible');
          grid.appendChild(el);
          void el.offsetWidth;
          if (el.style.display !== 'none') el.classList.add('is-visible');
        });
        syncStateToUrl();
        updateStateSummary();
      });
    });

    const urlSort = url.searchParams.get('sort');
    if (urlSort) {
      const targetSortBtn = sortBtns.find((b) => b.dataset.sort === urlSort);
      if (targetSortBtn) targetSortBtn.click();
      else syncStateToUrl();
    }
    updateStateSummary();
  </script>
</BaseLayout>
