---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Lightbox from '../../components/Lightbox.astro';
import { withBase } from '../../utils/withBase';
import { formatDate } from '../../utils/format';
import { aiLevelLabels, branchingLabels } from '../../utils/labels';
import { SITE_NAME, EXTERNAL_LINKS, COMING_SOON_YEAR } from '../../utils/constants';
import { buildProductSchema } from '../../utils/schema';
import { buildLinks, PURCHASE_LINK_ENTRIES, TRIAL_LINK_ENTRIES } from '../../utils/types';
import { getSortedWorks, buildPrevNext, getCharactersByWork } from '../../utils/collections';
import Breadcrumb from '../../components/Breadcrumb.astro';
import StoreSidebar from '../../components/StoreSidebar.astro';
import ArticlePagination from '../../components/ArticlePagination.astro';
import FabPurchase from '../../components/FabPurchase.astro';
import EarlyAccessDownload from '../../components/EarlyAccessDownload.astro';

export async function getStaticPaths() {
  return buildPrevNext(await getSortedWorks());
}

const { entry, prev, next } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;

const workCharacters = await getCharactersByWork(entry.slug);
const sidebarChars = workCharacters.map((c) => ({
  slug: c.slug,
  name: c.data.name,
  cover: c.data.cover,
}));

const productJsonLd = buildProductSchema({
  title: data.title,
  description: data.shortDescription,
  os: data.environments.windows ? 'Windows' : 'Web Browser',
  datePublished: data.releaseDate,
});

const isComingSoon = data.releaseDate.getFullYear() >= COMING_SOON_YEAR;

const platformLinks = buildLinks(data.platformLinks, PURCHASE_LINK_ENTRIES);
const trialLinks = data.trialLinks ? buildLinks(data.trialLinks, TRIAL_LINK_ENTRIES) : [];
---

<BaseLayout
  title={`${data.title} — ${data.shortDescription} | ${SITE_NAME}`}
  description={data.shortDescription}
  image={data.images.cover}
  jsonLd={productJsonLd}
>
  <div class="page-content">
    <div class="container">
      <Breadcrumb crumbs={[
        { label: '作品', href: withBase('works/') },
        { label: data.title },
      ]} />
      <!-- 上部コンパクトナビ（ページ末尾まで戻らずに前後作品へ移動できる） -->
      {(prev || next) && (
        <nav class="work-top-nav" aria-label="前後の作品へ">
          {prev
            ? <a class="work-top-nav-link" href={withBase(`works/${prev.slug}/`)}>← {prev.data.title}</a>
            : <span></span>
          }
          {next && (
            <a class="work-top-nav-link work-top-nav-link--next" href={withBase(`works/${next.slug}/`)}>{next.data.title} →</a>
          )}
        </nav>
      )}
    </div>
    <!-- Hero Banner -->
    <section class="section container">
      <div class="detail-title-wrapper" data-anim>
        <h1 class="section-title detail-title">{data.title}</h1>
        <p class="muted detail-catch">{data.catch}</p>
      </div>

      <div class="detail-layout">
        <!-- Main Column -->
        <div class="detail-main">
          <!-- Cover Image -->
          <div
            class="work-cover"
            data-anim
            style="--anim-delay: 0.1s"
            data-lightbox-src={withBase(data.images.cover)}
            data-lightbox-type="image"
            data-lightbox-alt={`${data.title} cover`}
            role="button"
            tabindex="0"
            aria-label={`${data.title}の画像を拡大する`}
            title="クリックで拡大"
          >
            <img src={withBase(data.images.cover)} alt={`${data.title} cover`} width="720" height="480" fetchpriority="high" loading="eager" />
            <div class="work-cover-zoom-hint" aria-hidden="true">🔍</div>
          </div>

          <!-- Video -->
          {data.videoUrl && (
            <div class="work-video">
              <video controls preload="metadata" width="1280" height="720">
                <source src={data.videoUrl} type="video/mp4" />
              </video>
            </div>
          )}

          <!-- Screenshots -->
          {data.images.screenshots.length > 0 && (
            <div class="gallery-grid">
              {data.images.screenshots.map((image, j) => (
                <div
                  class="gallery-item"
                  data-lightbox-src={withBase(image)}
                  data-lightbox-type="image"
                  data-lightbox-alt={`${data.title} スクリーンショット ${j + 1}`}
                >
                  <img src={withBase(image)} alt={`${data.title} スクリーンショット ${j + 1}`} loading="lazy" width="400" height="225" />
                </div>
              ))}
            </div>
          )}

          <!-- Description Block -->
          <div class="detail-block" data-anim style="--anim-delay: 0.15s">
            <h2>概要</h2>
            <p>{data.shortDescription}</p>
            {data.sellingPoints && data.sellingPoints.length > 0 && (
              <ul class="selling-points">
                {data.sellingPoints.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            )}
            <Content />
          </div>
        </div>

        <!-- Sidebar -->
        <StoreSidebar
          isR18={data.isR18}
          trialLinks={trialLinks}
          purchaseLinks={platformLinks}
          characters={sidebarChars}
          location="work_sidebar"
          shareUrl={Astro.url.href}
          shareTitle={data.title}
        >
          <Fragment slot="before-purchase">
            {data.earlyAccess?.enabled && (
              <>
                <h3>先行体験版</h3>
                <EarlyAccessDownload
                  password={data.earlyAccess.password}
                  downloadUrl={data.earlyAccess.downloadUrl}
                  cienUrl={EXTERNAL_LINKS.cien}
                />
              </>
            )}
          </Fragment>

          <Fragment slot="after-purchase">
            {platformLinks.length === 0 && (
              <div class="sidebar-coming-soon">
                <p class="sidebar-small">販売情報は後日公開予定</p>
                <a class="button button--cien button--block" href={EXTERNAL_LINKS.cien}
                   target="_blank" rel="noopener noreferrer">
                  Ci-en で進捗を見る →
                </a>
                <a class="button button--cien button--block" href={withBase('news/')}>
                  開発ログを見る →
                </a>
              </div>
            )}

            <h3>仕様</h3>
            <table class="spec-table">
              <tbody>
                <tr>
                  <td>リリース日</td>
                  <td>{isComingSoon ? '未定' : formatDate(data.releaseDate)}</td>
                </tr>
                <tr>
                  <td>プレイ時間</td>
                  <td>{data.volume.playTimeMin} 分</td>
                </tr>
                <tr>
                  <td>CG枚数</td>
                  <td>{data.volume.cgCount === 0 ? '後日公開' : `${data.volume.cgCount} 枚`}</td>
                </tr>
                <tr>
                  <td>Hシーン</td>
                  <td>{data.volume.hSceneCount === 0 ? '後日公開' : `${data.volume.hSceneCount} シーン`}</td>
                </tr>
                <tr>
                  <td>分岐</td>
                  <td>{branchingLabels[data.volume.branching] ?? data.volume.branching}</td>
                </tr>
              </tbody>
            </table>

            <h3>対応環境</h3>
            <div class="env-tags">
              <span class={`env-tag ${data.environments.windows ? 'env-tag--yes' : 'env-tag--no'}`}>
                Windows
              </span>
              <span class={`env-tag ${data.environments.mac ? 'env-tag--yes' : 'env-tag--no'}`}>
                Mac
              </span>
              <span class={`env-tag ${data.environments.browserPc ? 'env-tag--yes' : 'env-tag--no'}`}>
                ブラウザ PC
              </span>
              <span class={`env-tag ${data.environments.browserMobileBeta ? 'env-tag--yes' : 'env-tag--no'}`}>
                モバイル β
              </span>
            </div>
          </Fragment>

          <Fragment slot="after-chars">
            <div class="sidebar-divider">
              <p class="sidebar-small">
                AI使用: {aiLevelLabels[data.aiUsage.level] ?? data.aiUsage.level}
              </p>
              <p class="sidebar-xsmall">
                {data.aiUsage.noteShort}
              </p>
            </div>
          </Fragment>
        </StoreSidebar>
      </div>
    </section>

    <Lightbox itemSelector=".work-cover, .gallery-item" />

    <section class="container section--compact">
      <div class="notice">
        販売・決済・納品は外部ストアが担当します。
      </div>
      <ArticlePagination
        prev={prev}
        next={next}
        basePath="works/"
        prevLabel="前の作品"
        nextLabel="次の作品"
        ariaLabel="作品ナビゲーション"
        centerHref={withBase('works/')}
        centerText="作品一覧"
        centerBackContextKey="works"
      />
    </section>
  </div>

  {platformLinks.length > 0 && <FabPurchase targetId="purchase-section" />}
</BaseLayout>
