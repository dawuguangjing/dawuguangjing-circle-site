---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Lightbox from '../../components/Lightbox.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../utils/withBase';
import { formatDate } from '../../utils/format';
import { aiLevelLabels, branchingLabels } from '../../utils/labels';
import { SITE_NAME } from '../../utils/constants';
import { buildProductSchema } from '../../utils/schema';
import { buildLinks } from '../../utils/types';
import Breadcrumb from '../../components/Breadcrumb.astro';
import StoreButtonGroup from '../../components/StoreButtonGroup.astro';
import FabPurchase from '../../components/FabPurchase.astro';

export async function getStaticPaths() {
  const works = (await getCollection('works')).sort(
    (a, b) => b.data.releaseDate.getTime() - a.data.releaseDate.getTime()
  );
  return works.map((entry, i) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      prevWork: works[i + 1] ?? null,
      nextWork: works[i - 1] ?? null,
    }
  }));
}

const { entry, prevWork, nextWork } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;

const productJsonLd = buildProductSchema({
  title: data.title,
  description: data.shortDescription,
  os: data.environments.windows ? 'Windows' : 'Web Browser',
  datePublished: data.releaseDate,
});

const platformLinks = buildLinks(data.platformLinks, [
  { key: 'fanza', label: 'FANZA で購入', track: 'click_fanza', store: 'fanza' },
  { key: 'dlsite', label: 'DLsite で購入', track: 'click_dlsite', store: 'dlsite' },
]);

const trialLinks = data.trialLinks
  ? buildLinks(data.trialLinks, [
      { key: 'fanza', label: 'FANZA 体験版', track: 'click_trial_fanza', store: 'fanza' },
      { key: 'dlsite', label: 'DLsite 体験版', track: 'click_trial_dlsite', store: 'dlsite' },
    ])
  : [];
---

<BaseLayout
  title={`${data.title} — ${data.shortDescription} | ${SITE_NAME}`}
  description={data.shortDescription}
  image={data.images.cover}
  jsonLd={productJsonLd}
>
  <div class="page-content">
    <div class="container">
      <Breadcrumb crumbs={[
        { label: 'ストア', href: withBase('works/') },
        { label: data.title },
      ]} />
      <!-- 上部コンパクトナビ（ページ末尾まで戻らずに前後作品へ移動できる） -->
      {(prevWork || nextWork) && (
        <nav class="work-top-nav" aria-label="前後の作品へ">
          {prevWork
            ? <a class="work-top-nav-link" href={withBase(`works/${prevWork.slug}/`)}>← {prevWork.data.title}</a>
            : <span></span>
          }
          {nextWork && (
            <a class="work-top-nav-link work-top-nav-link--next" href={withBase(`works/${nextWork.slug}/`)}>{nextWork.data.title} →</a>
          )}
        </nav>
      )}
    </div>
    <!-- Hero Banner -->
    <section class="section container">
      <div class="detail-title-wrapper" data-anim>
        <h1 class="section-title detail-title">{data.title}</h1>
        <p class="muted detail-catch">{data.catch}</p>
      </div>

      <div class="detail-layout">
        <!-- Main Column -->
        <div class="detail-main">
          <!-- Cover Image -->
          <div
            class="work-cover"
            data-anim
            style="--anim-delay: 0.1s"
            data-lightbox-src={withBase(data.images.cover)}
            data-lightbox-type="image"
            data-lightbox-alt={`${data.title} cover`}
          >
            <img src={withBase(data.images.cover)} alt={`${data.title} cover`} width="720" height="480" fetchpriority="high" loading="eager" />
          </div>

          <!-- Video -->
          {data.videoUrl && (
            <div class="work-video">
              <video controls preload="metadata" width="1280" height="720">
                <source src={data.videoUrl} type="video/mp4" />
              </video>
            </div>
          )}

          <!-- Screenshots -->
          {data.images.screenshots.length > 0 && (
            <div class="gallery-grid">
              {data.images.screenshots.map((image, j) => (
                <div
                  class="gallery-item"
                  data-lightbox-src={withBase(image)}
                  data-lightbox-type="image"
                  data-lightbox-alt={`${data.title} スクリーンショット ${j + 1}`}
                >
                  <img src={withBase(image)} alt={`${data.title} スクリーンショット ${j + 1}`} loading="lazy" width="400" height="225" />
                </div>
              ))}
            </div>
          )}

          <!-- Description Block -->
          <div class="detail-block" data-anim style="--anim-delay: 0.15s">
            <h2>概要</h2>
            <p>{data.shortDescription}</p>
            {data.sellingPoints && data.sellingPoints.length > 0 && (
              <ul class="selling-points">
                {data.sellingPoints.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            )}
            <Content />
          </div>
        </div>

        <!-- Sidebar -->
        <div class="store-sidebar" id="purchase-section" data-anim="slide-right" style="--anim-delay: 0.2s">
          <!-- Age Rating -->
          <div>
            {data.isR18
              ? <span class="badge badge--r18">R18 作品</span>
              : <span class="badge">全年齢</span>
            }
          </div>

          <!-- Trial Buttons（先に試せる導線） -->
          {trialLinks.length > 0 && (
            <>
              <h3>体験版を試す</h3>
              <StoreButtonGroup links={trialLinks} trial />
            </>
          )}

          <!-- Purchase Buttons -->
          <h3>購入する</h3>
          <StoreButtonGroup links={platformLinks} />

          <!-- Spec Table -->
          <h3>仕様</h3>
          <table class="spec-table">
            <tbody>
              <tr>
                <td>リリース日</td>
                <td>{formatDate(data.releaseDate)}</td>
              </tr>
              <tr>
                <td>プレイ時間</td>
                <td>{data.volume.playTimeMin} 分</td>
              </tr>
              <tr>
                <td>CG枚数</td>
                <td>{data.volume.cgCount} 枚</td>
              </tr>
              <tr>
                <td>Hシーン</td>
                <td>{data.volume.hSceneCount} シーン</td>
              </tr>
              <tr>
                <td>分岐</td>
                <td>{branchingLabels[data.volume.branching] ?? data.volume.branching}</td>
              </tr>
            </tbody>
          </table>

          <!-- Environment -->
          <h3>対応環境</h3>
          <div class="env-tags">
            <span class={`env-tag ${data.environments.windows ? 'env-tag--yes' : 'env-tag--no'}`}>
              Windows
            </span>
            <span class={`env-tag ${data.environments.mac ? 'env-tag--yes' : 'env-tag--no'}`}>
              Mac
            </span>
            <span class={`env-tag ${data.environments.browserPc ? 'env-tag--yes' : 'env-tag--no'}`}>
              ブラウザ PC
            </span>
            <span class={`env-tag ${data.environments.browserMobileBeta ? 'env-tag--yes' : 'env-tag--no'}`}>
              モバイル β
            </span>
          </div>

          <!-- AI Usage -->
          <div class="sidebar-divider">
            <p class="sidebar-small">
              AI使用: {aiLevelLabels[data.aiUsage.level] ?? data.aiUsage.level}
            </p>
            <p class="sidebar-xsmall">
              {data.aiUsage.noteShort}
            </p>
          </div>
        </div>
      </div>
    </section>

    <Lightbox itemSelector=".work-cover, .gallery-item" />

    <section class="container section--compact">
      <div class="notice">
        販売・決済・納品は外部ストアが担当します。
      </div>
      <nav class="work-pagination" aria-label="作品ナビゲーション">
        <div class="work-pagination-prev">
          {prevWork && (
            <a class="work-pagination-link" href={withBase(`works/${prevWork.slug}/`)}>
              <span class="work-pagination-arrow">←</span>
              <span class="work-pagination-meta">
                <span class="work-pagination-label">前の作品</span>
                <span class="work-pagination-title">{prevWork.data.title}</span>
              </span>
            </a>
          )}
        </div>
        <div class="work-pagination-center">
          <a class="section-link" href={withBase('works/')}>作品一覧</a>
        </div>
        <div class="work-pagination-next">
          {nextWork && (
            <a class="work-pagination-link work-pagination-link--next" href={withBase(`works/${nextWork.slug}/`)}>
              <span class="work-pagination-meta">
                <span class="work-pagination-label">次の作品</span>
                <span class="work-pagination-title">{nextWork.data.title}</span>
              </span>
              <span class="work-pagination-arrow">→</span>
            </a>
          )}
        </div>
      </nav>
    </section>
  </div>

  <FabPurchase targetId="purchase-section" />
</BaseLayout>
